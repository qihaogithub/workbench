# ============================================
# OpenCode Server LLM API 配置
# ============================================

# ── 方式一：单供应商配置（简单模式）──

# 供应商名称（决定模型 ID 前缀，如 "deepseek" → 模型显示为 "deepseek/deepseek-chat"）
# 不设置时默认为 "custom"
OPENCODE_PROVIDER_NAME=xjjj

# API Key
OPENCODE_API_KEY=sk-WVZggReZJwlES2Bo0FCkZvAw5D3inMpXlfOzGBZixSgYvEw5

# API 基础地址（OpenAI 兼容格式）
OPENCODE_API_BASE=https://token.xjjj.co/v1

# 模型名称（多个模型用逗号分隔）
OPENCODE_MODELS=deepseek-v4-flash

# ── 方式二：多供应商配置（JSON 格式，优先级高于方式一）──
# 取消注释以下变量即可启用，同时注释掉方式一的变量
#
# OPENCODE_PROVIDERS='[{"id":"deepseek","name":"DeepSeek","baseURL":"https://api.deepseek.com/v1","apiKey":"sk-xxx","models":["deepseek-chat","deepseek-reasoner"]},{"id":"qwen","name":"通义千问","baseURL":"https://dashscope.aliyuncs.com/compatible-mode/v1","apiKey":"sk-yyy","models":["qwen-plus"]}]'
# OPENCODE_DEFAULT_MODEL=deepseek/deepseek-chat

# ============================================
# 前端模型白名单配置
# ============================================

# 允许在前端显示的模型前缀（逗号分隔）
# 必须与 OPENCODE_PROVIDER_NAME 或 OPENCODE_PROVIDERS 中的 id 对应
# 例如：OPENCODE_PROVIDER_NAME=deepseek → 这里填 deepseek/
# 多供应商时：NEXT_PUBLIC_ALLOWED_MODEL_PREFIXES=deepseek/,qwen/
NEXT_PUBLIC_ALLOWED_MODEL_PREFIXES=xjjj/

# ============================================
# 服务地址配置
# ============================================

# 外部访问地址（局域网部署时修改为实际 IP）
NEXT_PUBLIC_AGENT_SERVICE_URL=http://10.130.33.131:3201
NEXT_PUBLIC_WEB_URL=http://10.130.33.131:3200

# CORS 允许的来源
CORS_ORIGINS=http://10.130.33.131:3200,http://10.130.33.131:3300,http://localhost:3200,http://localhost:3300,http://127.0.0.1:3200,http://127.0.0.1:3300

# JWT 密钥（生产环境请修改为随机字符串）
JWT_SECRET=change-this-to-a-random-string
