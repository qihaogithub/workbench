# ============================================
# OpenCode Server LLM API 配置
# 修改这里来更换你的大模型 API
# ============================================

# 你的 API Key
OPENCODE_API_KEY=sk-your-api-key-here

# API 基础地址（OpenAI 兼容格式）
# 例如：https://api.deepseek.com/v1
# 例如：https://dashscope.aliyuncs.com/compatible-mode/v1
OPENCODE_API_BASE=https://api.example.com/v1

# 模型名称
# 例如：deepseek-chat、qwen-plus、gpt-4o 等
OPENCODE_MODELS=your-model-name

# ============================================
# 服务地址配置
# ============================================

# 外部访问地址（局域网部署时修改为实际 IP）
NEXT_PUBLIC_AGENT_SERVICE_URL=http://192.168.x.x:3201
NEXT_PUBLIC_WEB_URL=http://192.168.x.x:3200

# CORS 允许的来源
CORS_ORIGINS=http://192.168.x.x:3200,http://192.168.x.x:3300,http://localhost:3200,http://localhost:3300

# JWT 密钥（生产环境请修改为随机字符串）
JWT_SECRET=change-this-to-a-random-string