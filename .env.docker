# ============================================
# 前端模型白名单配置
# ============================================

# 允许在前端显示的模型前缀（逗号分隔）
# 必须与管理后台「AI 后端供应商」中的供应商 id 对应
# 例如：供应商 id = deepseek → 这里填 deepseek/
# 多供应商时：NEXT_PUBLIC_ALLOWED_MODEL_PREFIXES=deepseek/,qwen/
NEXT_PUBLIC_ALLOWED_MODEL_PREFIXES=xjjj/,jojo/

# ── 分组名称过滤：仅保留名称包含关键词的模型（逗号分隔，格式: 分组:关键词）──
# 例如 opencode:Free 表示 opencode 分组下仅保留名称含 "Free" 的模型
# 大小写不敏感;未配置的分组不受限制
NEXT_PUBLIC_MODEL_NAME_FILTERS=opencode:Free

# ============================================
# 服务地址配置
# ============================================

# 外部访问地址（局域网部署时修改为实际 IP）
NEXT_PUBLIC_AGENT_SERVICE_URL=http://10.130.33.131:3201
NEXT_PUBLIC_WEB_URL=http://10.130.33.131:3200

# CORS 允许的来源
CORS_ORIGINS=http://10.130.33.131:3200,http://10.130.33.131:3300,http://localhost:3200,http://localhost:3300,http://127.0.0.1:3200,http://127.0.0.1:3300

# ============================================
# 认证与安全配置
# ============================================

# JWT 密钥（生产环境请修改为随机字符串）
JWT_SECRET=change-this-to-a-random-string

# Cookie Secure 标志配置
# - true: 仅 HTTPS 连接可设置 Cookie（适用于 HTTPS 部署）
# - false: HTTP 连接也可设置 Cookie（适用于 HTTP 内网部署）
# 默认值: true（推荐 HTTPS 部署时保持默认）
# 注意: 如果通过 HTTP 访问（如 http://10.130.33.131:3200），必须设置为 false，否则登录会失败
USE_SECURE_COOKIE=false

# ============================================
# 管理后台配置
# ============================================

# 管理后台访问密钥 (生产环境必须修改为强随机字符串)
ADMIN_SECRET=admin-change-this-to-random-string
