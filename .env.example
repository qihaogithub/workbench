# Opencode Workbench local development environment
#
# Copy values into .env when needed. Keep .env private.

# ============================================
# author-site
# ============================================

# Required for login/session cookies in author-site.
JWT_SECRET=change-this-local-jwt-secret

# Local agent service URL used by author-site server-side API calls.
AGENT_SERVICE_URL=http://localhost:3201
NEXT_PUBLIC_AGENT_SERVICE_URL=http://localhost:3201

# Optional screenshot service URL. Required only for screenshot workflows.
SCREENSHOT_SERVICE_URL=http://localhost:3202
NEXT_PUBLIC_SCREENSHOT_SERVICE_URL=http://localhost:3202

# Shared internal token for author-site -> agent-service calls.
# Keep the same value in all services when enabled.
INTERNAL_API_TOKEN=local-internal-token

# Admin panel secret. Required only for admin routes.
ADMIN_SECRET=local-admin-secret

# Optional Figma OAuth for user-level Figma MCP authorization.
# Create a Figma OAuth app and set the redirect URI to:
# http://localhost:3200/api/user/external-auth/figma/callback
FIGMA_OAUTH_CLIENT_ID=
FIGMA_OAUTH_CLIENT_SECRET=
FIGMA_OAUTH_REDIRECT_URI=http://localhost:3200/api/user/external-auth/figma/callback
# Optional: where the browser returns after OAuth. Useful when redirect URI uses a public tunnel.
# FIGMA_OAUTH_POST_AUTH_ORIGIN=http://localhost:3200
# FIGMA_OAUTH_SCOPES=file_content:read

# Use false for local HTTP development.
USE_SECURE_COOKIE=false

# Optional data directory override. Defaults to ./data when unset.
# DATA_DIR=./data

# ============================================
# agent-service
# ============================================

PORT=3201
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3200,http://localhost:3300

# Required only when running real Pi Agent calls.
PI_AGENT_API_KEY=
PI_AGENT_PROVIDER=jojo
PI_AGENT_MODEL=deepseek-v4-flash
PI_AGENT_BASE_URL=
PI_AGENT_TIMEOUT=120000

# Optional subagent controls.
PI_AGENT_SUBAGENTS_ENABLED=true
PI_AGENT_SUBAGENT_TIMEOUT=120000

# Optional web page reading tool. Enabled by default; set to false to disable public URL reads.
PI_AGENT_WEB_READ_ENABLED=true
PI_AGENT_WEB_READ_TIMEOUT_MS=10000
PI_AGENT_WEB_READ_MAX_BYTES=1000000

# Optional web search tool. Requires a Brave Search API key.
PI_AGENT_WEB_SEARCH_ENABLED=false
BRAVE_SEARCH_API_KEY=
PI_AGENT_WEB_SEARCH_TIMEOUT_MS=10000
PI_AGENT_WEB_SEARCH_CACHE_TTL_MS=600000

# Optional Figma MCP endpoint override. Defaults to https://mcp.figma.com/mcp when unset.
# FIGMA_MCP_URL=https://mcp.figma.com/mcp
# FIGMA_MCP_REGION=

# ============================================
# screenshot-service
# ============================================

AUTHOR_SITE_URL=http://localhost:3200

# Required only when Puppeteer cannot auto-detect a local browser.
# PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# ============================================
# viewer-site
# ============================================

NEXT_PUBLIC_DATA_BASE=http://localhost:3200

# ============================================
# E2E
# ============================================

E2E_BASE_URL=http://localhost:3200
E2E_USER=qihao
E2E_PASSWORD=130015

# ============================================
# Optional OSS publish assets
# ============================================

# OSS_REGION=oss-cn-hangzhou
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET=opencode-workbench-assets
# OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# OSS_PATH_PREFIX=projects
