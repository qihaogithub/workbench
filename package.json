{
  "name": "opencode-workbench",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n web,agent -c blue,green \"pnpm --filter @opencode-workbench/web dev\" \"pnpm --filter @opencode-workbench/agent-service dev\"",
    "dev:web": "pnpm --filter @opencode-workbench/web dev",
    "dev:agent": "pnpm --filter @opencode-workbench/agent-service dev",
    "build": "pnpm --filter @opencode-workbench/web build",
    "lint": "pnpm --filter @opencode-workbench/web lint",
    "typecheck": "pnpm --filter @opencode-workbench/web typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=18.0.0"
  }
}
