{
  "name": "opencode-workbench",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n author,agent,viewer,sshot -c blue,green,cyan,yellow \"pnpm --filter @opencode-workbench/author-site dev\" \"pnpm --filter @opencode-workbench/agent-service dev\" \"pnpm --filter @opencode-workbench/viewer-site dev\" \"pnpm --filter @opencode-workbench/screenshot-service dev\"",
    "dev:author": "pnpm --filter @opencode-workbench/author-site dev",
    "dev:preview": "concurrently -n author,sshot -c blue,yellow \"pnpm --filter @opencode-workbench/author-site dev\" \"pnpm --filter @opencode-workbench/screenshot-service dev\"",
    "dev:agent": "pnpm --filter @opencode-workbench/agent-service dev",
    "dev:viewer": "pnpm --filter @opencode-workbench/viewer-site dev",
    "dev:snapshot:legacy": "pnpm --filter @opencode-workbench/snapshot-service dev",
    "dev:screenshot": "pnpm --filter @opencode-workbench/screenshot-service dev",
    "build": "pnpm --filter @opencode-workbench/author-site build",
    "build:viewer": "pnpm --filter @opencode-workbench/viewer-site build",
    "lint": "pnpm --filter @opencode-workbench/author-site lint",
    "typecheck": "pnpm --filter @opencode-workbench/author-site typecheck",
    "typecheck:viewer": "pnpm --filter @opencode-workbench/viewer-site typecheck",
    "check:author": "pnpm --filter @opencode-workbench/author-site typecheck && pnpm --filter @opencode-workbench/author-site test",
    "check:agent": "pnpm --filter @opencode-workbench/agent-service typecheck && pnpm --filter @opencode-workbench/agent-service test",
    "check:screenshot": "pnpm --filter @opencode-workbench/screenshot-service typecheck && pnpm --filter @opencode-workbench/screenshot-service test",
    "check:project-core": "pnpm --filter @opencode-workbench/project-core typecheck && pnpm --filter @opencode-workbench/project-core test",
    "check:project-scaffold": "pnpm --filter @opencode-workbench/project-scaffold typecheck && pnpm --filter @opencode-workbench/project-scaffold test",
    "check:project-cli": "pnpm --filter @opencode-workbench/project-cli typecheck && pnpm --filter @opencode-workbench/project-cli test",
    "check:knowledge-core": "pnpm --filter @opencode-workbench/knowledge-core typecheck && pnpm --filter @opencode-workbench/knowledge-core test",
    "check:knowledge-service": "pnpm --filter @opencode-workbench/knowledge-service typecheck && pnpm --filter @opencode-workbench/knowledge-service test",
    "check:viewer": "pnpm --filter @opencode-workbench/viewer-site typecheck",
    "check:all": "pnpm check:knowledge-core && pnpm check:knowledge-service && pnpm check:project-core && pnpm check:project-scaffold && pnpm check:project-cli && pnpm check:agent && pnpm check:screenshot && pnpm check:author && pnpm check:viewer",
    "test:e2e": "playwright test --config test/新建-编辑-保存项目测试/playwright.config.ts",
    "test:e2e:ui": "playwright test --config test/新建-编辑-保存项目测试/playwright.config.ts --ui",
    "test:e2e:headed": "playwright test --config test/新建-编辑-保存项目测试/playwright.config.ts --headed",
    "test:ai-workspace-refresh": "node scripts/development/test-ai-workspace-refresh.mjs",
    "test:knowledge-validation": "node scripts/development/knowledge-validation-suite.mjs metrics",
    "test:knowledge-validation:run": "node scripts/development/knowledge-validation-suite.mjs run"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=18.0.0"
  }
}
