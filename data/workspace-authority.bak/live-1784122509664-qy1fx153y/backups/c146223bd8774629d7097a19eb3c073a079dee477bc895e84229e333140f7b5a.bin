{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "核心流程回归配置",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "title": "标题",
      "default": "核心流程回归"
    },
    "description": {
      "type": "string",
      "title": "描述",
      "default": "用于验证创作端新建、编辑、保存和读取链路。"
    },
    "enabled": {
      "type": "boolean",
      "title": "启用状态",
      "default": true
    }
  },
  "required": [
    "title",
    "description"
  ]
}{
