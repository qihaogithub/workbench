{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "表单控件合集",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "title": "标题",
      "default": "表单控件合集"
    },
    "description": {
      "type": "string",
      "title": "描述",
      "default": "丰富的表单控件演示，包含输入框、选择器、开关等常用组件"
    },
    "primaryColor": {
      "type": "string",
      "title": "主题色",
      "default": "#4F46E5"
    },
    "showLabels": {
      "type": "boolean",
      "title": "显示标签",
      "default": true
    }
  },
  "required": ["title"]
}