{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$demo": {
    "previewSize": {
      "width": 1024,
      "height": 768
    }
  },
  "title": "课后服务 - 平板版配置",
  "type": "object",
  "properties": {
    "serviceTitle": {
      "type": "string",
      "title": "服务标题",
      "default": "全年系统包-L1"
    },
    "teacherName": {
      "type": "string",
      "title": "指导师名称",
      "default": "苹果指导师"
    },
    "feature1Name": {
      "type": "string",
      "title": "功能1名称",
      "default": "学习报告"
    },
    "feature1Status": {
      "type": "string",
      "title": "功能1状态",
      "default": "3篇报告未读"
    },
    "feature2Name": {
      "type": "string",
      "title": "功能2名称",
      "default": "活动挑战"
    },
    "feature3Name": {
      "type": "string",
      "title": "功能3名称",
      "default": "随堂故事"
    },
    "historyText": {
      "type": "string",
      "title": "底部链接文字",
      "default": "查看往期课程"
    }
  }
}
