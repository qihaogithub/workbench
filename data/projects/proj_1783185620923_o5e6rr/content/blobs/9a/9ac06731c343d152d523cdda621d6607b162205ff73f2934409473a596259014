.outside-guide { --outside-max: 420px; --outside-hero-height: clamp(382px, 110vw, 462px); --outside-prize-overlap: clamp(-96px, calc(24vw - 172px), -72px); --outside-radius: 22px; --outside-yellow: #fcda00; --outside-yellow-deep: #544300; --outside-green: #4aa12d; --outside-grass: #9acb07; --outside-grass-deep: #5f9d0c; --outside-card: #f1ffde; --outside-line: #cbee9d; --outside-ink: #404040; --outside-muted: #666666; position: relative; display: flex; flex-direction: column; width: 100%; min-height: 812px; max-width: none; margin: 0px auto; overflow: hidden auto; background: rgb(1, 96, 28); color: var(--outside-ink); }
.outside-bg { display: none; }
.outside-content { position: relative; z-index: 1; display: flex; flex: 0 0 auto; flex-direction: column; align-items: stretch; padding: 0px 10px 18px; }
.outside-app-top { position: relative; z-index: 0; margin: 0px -10px; padding-bottom: 0px; }
.outside-app-hero { position: relative; z-index: 0; width: 100%; height: var(--outside-hero-height); background: url("data:image/webp;base64,") center top / 100% no-repeat; pointer-events: none; }
.outside-prize-showcase { position: relative; z-index: 1; margin: var(--outside-prize-overlap) 10px 18px; padding: 11px 9px; border-radius: 22px; background: linear-gradient(rgba(255, 255, 255, 0.26), rgba(255, 255, 255, 0)), rgb(216, 244, 162); box-shadow: rgba(163, 216, 74, 0.74) 0px 0px 0px 3px inset, rgba(59, 126, 5, 0.2) 0px 8px 20px; }
.outside-prize-showcase::before { content: ""; position: absolute; inset: 6px; border-radius: 17px; background: var(--outside-card); pointer-events: none; }
.outside-prize-scroll { position: relative; z-index: 1; display: flex; gap: 8px; overflow-x: auto; padding: 0px; scrollbar-width: none; }
.outside-prize-scroll::-webkit-scrollbar { display: none; }
.outside-prize-item { flex: 0 0 78px; display: flex; flex-direction: column; align-items: center; gap: 3px; min-height: 96px; padding: 5px 4px; border-top-color: ; border-top-style: ; border-top-width: ; border-right-color: ; border-right-style: ; border-right-width: ; border-bottom-color: ; border-bottom-style: ; border-left-color: ; border-left-style: ; border-left-width: ; border-image-source: ; border-image-slice: ; border-image-width: ; border-image-outset: ; border-image-repeat: ; border-bottom-width: 4px; border-radius: 14px; background: linear-gradient(rgba(255, 255, 255, 0), rgb(255, 255, 255)); }
.outside-prize-art { display: grid; place-items: center; width: 56px; height: 52px; border: 1px solid rgba(137, 213, 77, 0.3); border-radius: 13px; background: radial-gradient(circle at 50% 20%, rgba(255, 255, 255, 0.9), transparent 42%), rgb(236, 255, 213); overflow: hidden; }
.outside-prize-art--trial, .outside-prize-art--vip { background: radial-gradient(circle at 50% 18%, rgba(255, 255, 255, 0.86), transparent 44%), linear-gradient(rgb(255, 249, 183), rgb(221, 248, 179)); }
.outside-prize-art img { width: 100%; height: 100%; object-fit: cover; }
.outside-prize-item strong { display: flex; align-items: center; justify-content: center; flex: 1 1 0%; width: 100%; color: var(--outside-ink); font-size: 9px; font-weight: 700; line-height: 1.08; text-align: center; overflow-wrap: anywhere; }
.outside-prize-item > span { display: none; }
.outside-prize-item:nth-child(3) { order: 1; }
.outside-prize-item:nth-child(2) { order: 2; }
.outside-prize-item:nth-child(4) { order: 3; }
.outside-prize-item:nth-child(1) { order: 4; }
.outside-prize-item:nth-child(5) { order: 5; }
.outside-prize-item:nth-child(8) { order: 6; }
.outside-prize-item:nth-child(7) { order: 7; }
.outside-prize-item:nth-child(9) { order: 8; }
.outside-prize-item:nth-child(6) { order: 9; }
.outside-prize-item:nth-child(10) { order: 10; }
.outside-qr-card { position: relative; z-index: 2; display: flex; flex-direction: column; align-items: center; gap: 11px; margin: 0px; padding: 14px 18px 16px; border: 2px solid rgba(255, 255, 255, 0.78); border-radius: 22px; background: linear-gradient(rgba(255, 255, 255, 0.98), rgba(246, 255, 232, 0.98)), rgb(255, 255, 255); color: var(--outside-ink); text-align: center; box-shadow: rgba(35, 88, 12, 0.18) 0px 12px 24px; }
.outside-qr-copy { display: flex; flex-direction: column; gap: 6px; align-items: center; }
.outside-qr-copy strong { color: rgb(31, 95, 34); font-size: 18px; font-weight: 800; line-height: 1.25; }
.outside-qr-frame { display: grid; place-items: center; box-sizing: border-box; width: min(176px, 100%); height: min(176px, -56px + 375px); aspect-ratio: 1 / 1; padding: 6px; border: 1px solid rgba(95, 157, 12, 0.2); border-radius: 18px; background: rgb(255, 255, 255); box-shadow: rgb(243, 255, 232) 0px 0px 0px 4px inset; }
.outside-qr-frame img { display: block; width: 100%; height: 100%; border-radius: 10px; user-select: none; }
.outside-qr-save-tip { margin: 0px; color: rgb(23, 63, 30); font-size: 18px; font-weight: 800; line-height: 1.35; }
.outside-browser-actions { position: relative; z-index: 2; display: flex; flex-direction: column; gap: 12px; align-items: center; margin-top: 10px; padding: 0px 24px; }
.outside-btn-download { position: relative; z-index: 1; display: flex; align-items: center; justify-content: center; width: 100%; height: 40px; padding: 0px 16px; border-radius: 30px; appearance: none; text-align: center; text-decoration: none; font-size: 16px; font-weight: 600; line-height: 1.5; transition: transform 0.16s; }
.outside-btn-download { width: auto; min-width: 188px; height: 34px; margin-top: 10px; padding: 0px 18px; border: 1px solid rgba(255, 255, 255, 0.58); background: rgba(255, 255, 255, 0.14); color: rgba(255, 255, 255, 0.88); font-size: 13px; font-weight: 500; box-shadow: none; backdrop-filter: blur(6px); }
.outside-btn-download:active { transform: translateY(1px) scale(0.99); }
.outside-footer { position: relative; z-index: 1; margin-top: auto; padding: 22px 16px calc(env(safe-area-inset-bottom) + 18px); color: rgba(255, 255, 255, 0.5); font-size: 12px; line-height: 1.4; text-align: center; }
.outside-footer p { margin: 0px; }
@media (max-width: 360px){.outside-content { padding-right: 8px; padding-left: 8px; }
.outside-qr-card { padding-right: 14px; padding-left: 14px; }
.outside-browser-actions { padding-right: 18px; padding-left: 18px; }
.outside-qr-copy strong { font-size: 18px; }}
@media (min-width: 768px){.outside-guide { width: var(--outside-max); max-width: var(--outside-max); }}
@media (prefers-reduced-motion: reduce){.outside-btn-download { transition: none; }}
* { box-sizing: border-box; margin: 0px; padding: 0px; -webkit-tap-highlight-color: transparent; }
img { display: block; }