{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "扩科卡片 - 项目级共享配置",
  "type": "object",
  "properties": {
    "resourceImageURL": {
      "type": "string",
      "format": "image",
      "title": "资源图",
      "description": "扩科卡片配图，两个页面共用",
      "default": "https://uiweb.oss-cn-chengdu.aliyuncs.com/img/%E5%AD%A6%E4%B9%A0%E9%A1%B5/%E6%89%A9%E7%A7%91%E5%8D%A1%E7%89%87/%E7%B4%A0%E6%9D%90%E5%9B%BE.png"
    },
    "subjectTheme": {
      "type": "string",
      "title": "科目主题",
      "description": "卡片配色主题",
      "default": "english",
      "enum": ["reading", "puzzle", "art", "writing", "english"]
    }
  }
}
