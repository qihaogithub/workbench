{
  "type": "object",
  "$demo": {
    "previewSize": { "width": 800, "height": 600 },
    "orderable": ["heroSection", "featureSection", "testimonialSection"],
    "orderableHorizontal": ["navHome", "navProducts", "navAbout", "navContact"],
    "positionable": {
      "items": ["badge1", "badge2", "badge3", "badge4", "logoImage"],
      "size": { "width": 686, "height": 220 },
      "defaults": {
        "badge1": { "x": 80, "y": 60 },
        "badge2": { "x": 260, "y": 60 },
        "badge3": { "x": 440, "y": 60 },
        "badge4": { "x": 170, "y": 180 },
        "logoImage": { "x": 500, "y": 130 }
      }
    }
  },
  "properties": {
    "heroSection": {
      "type": "string",
      "title": "首屏区域",
      "default": "欢迎来到我们的平台",
      "description": "页面顶部的主视觉区域"
    },
    "featureSection": {
      "type": "string",
      "title": "功能区域",
      "default": "核心功能展示",
      "description": "中间的功能介绍区域"
    },
    "testimonialSection": {
      "type": "string",
      "title": "评价区域",
      "default": "用户评价",
      "description": "底部的用户评价区域"
    },
    "navHome": {
      "type": "string",
      "title": "首页导航",
      "default": "首页",
      "description": "导航栏首页链接"
    },
    "navProducts": {
      "type": "string",
      "title": "产品导航",
      "default": "产品",
      "description": "导航栏产品链接"
    },
    "navAbout": {
      "type": "string",
      "title": "关于导航",
      "default": "关于",
      "description": "导航栏关于链接"
    },
    "navContact": {
      "type": "string",
      "title": "联系导航",
      "default": "联系我们",
      "description": "导航栏联系链接"
    },
    "badge1": {
      "type": "string",
      "title": "徽章1",
      "default": "NEW",
      "description": "可自由定位的徽章1"
    },
    "badge2": {
      "type": "string",
      "title": "徽章2",
      "default": "HOT",
      "description": "可自由定位的徽章2"
    },
    "badge3": {
      "type": "string",
      "title": "徽章3",
      "default": "PRO",
      "description": "可自由定位的徽章3"
    },
    "badge4": {
      "type": "string",
      "title": "徽章4",
      "default": "BETA",
      "description": "可自由定位的徽章4"
    },
    "logoImage": {
      "type": "string",
      "format": "image",
      "title": "Logo图片",
      "default": "",
      "description": "可自由定位的Logo图片，上传后图片将显示在画布中"
    }
  }
}
