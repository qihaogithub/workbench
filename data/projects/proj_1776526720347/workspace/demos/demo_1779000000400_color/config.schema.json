{
  "type": "object",
  "$demo": {
    "previewSize": { "width": 1024, "height": 768 }
  },
  "properties": {
    "primaryColor": {
      "type": "string",
      "format": "color",
      "title": "主色",
      "default": "#6366f1",
      "description": "品牌主色调（颜色选择器）",
      "$demo": {
        "note": "主色影响按钮、链接和高亮元素的颜色"
      }
    },
    "secondaryColor": {
      "type": "string",
      "format": "color",
      "title": "辅助色",
      "default": "#ec4899",
      "description": "辅助强调色（颜色选择器）"
    },
    "backgroundColor": {
      "type": "string",
      "format": "color",
      "title": "背景色",
      "default": "#f8fafc",
      "description": "页面背景颜色（颜色选择器）"
    },
    "heroImage": {
      "type": "string",
      "format": "image",
      "title": "主视觉图",
      "default": "https://picsum.photos/800/400",
      "description": "页面顶部的主视觉大图（图片上传）",
      "ui:options": {
        "accept": "image/*",
        "maxSize": 5242880,
        "minWidth": 400,
        "maxWidth": 2048,
        "maxHeight": 1024
      }
    },
    "galleryImages": {
      "type": "array",
      "title": "图片画廊",
      "description": "展示多张图片（多图上传）",
      "ui:widget": "imageList",
      "ui:options": {
        "maxItems": 8
      },
      "items": {
        "type": "string"
      },
      "default": [
        "https://picsum.photos/300/200?random=1",
        "https://picsum.photos/300/200?random=2",
        "https://picsum.photos/300/200?random=3"
      ]
    }
  }
}
