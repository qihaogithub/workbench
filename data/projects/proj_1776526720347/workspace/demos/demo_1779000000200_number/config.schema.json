{
  "type": "object",
  "$demo": {
    "previewSize": { "width": 1024, "height": 768 }
  },
  "properties": {
    "cardCount": {
      "type": "number",
      "title": "卡片数量",
      "default": 6,
      "minimum": 1,
      "maximum": 12,
      "description": "展示的卡片数量（滑块控制）"
    },
    "fontSize": {
      "type": "number",
      "title": "标题字号",
      "default": 20,
      "minimum": 14,
      "maximum": 48,
      "description": "卡片标题的字体大小（滑块控制）"
    },
    "borderWidth": {
      "type": "number",
      "title": "边框宽度",
      "default": 2,
      "minimum": 0,
      "maximum": 8,
      "description": "卡片边框的粗细（滑块控制）"
    },
    "spacing": {
      "type": "number",
      "title": "卡片间距",
      "default": 20,
      "minimum": 4,
      "maximum": 48,
      "description": "卡片之间的间距大小（滑块控制）"
    },
    "opacity": {
      "type": "number",
      "title": "不透明度",
      "default": 100,
      "minimum": 10,
      "maximum": 100,
      "description": "卡片的不透明度百分比（滑块控制）"
    },
    "priority": {
      "type": "integer",
      "title": "优先级",
      "default": 3,
      "minimum": 1,
      "maximum": 10,
      "description": "展示优先级（整数输入）"
    }
  }
}
