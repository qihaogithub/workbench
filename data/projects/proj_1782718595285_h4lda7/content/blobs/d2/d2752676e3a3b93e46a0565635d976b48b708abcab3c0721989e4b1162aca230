<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>demo - 副本</title>
  <link rel="stylesheet" href="./prototype.css" />
</head>
<body>
  <!-- 页面容器 -->
  <div class="page-container">
    
    <!-- 可滑动内容区域 -->
    <div class="scrollable-content">
      <div class="content-wrapper">
        
        <!-- 装饰层图片 -->
        <img 
          class="decorative-image" 
          src="https://r2-asset-worker.qihaogo.workers.dev/figma/h_e545eaf5.png" 
          alt="装饰背景" 
        />

        <!-- 邀友得奖模块 -->
        <div class="section invite-section">
          <div class="section-header">
            <span class="section-title">邀友得奖</span>
            <div class="section-link">
              <span class="link-text">邀请奖励记录</span>
              <svg class="link-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M6 4L10 8L6 12" stroke="#b2b2b2" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
          <div class="card-row">
            <div class="card" style="background-color: #FF6B35;">
              <img src="https://uiweb.oss-cn-chengdu.aliyuncs.com/img/%E6%88%91%E7%9A%84%E9%A1%B5/%E8%B5%84%E6%BA%90/%E9%82%80%E8%AF%B7%E6%B4%BB%E5%8A%A801.png" alt="邀请活动图片1" class="card-image" />
            </div>
            <div class="card" style="background-color: #F7C59F;">
              <img src="https://uiweb.oss-cn-chengdu.aliyuncs.com/img/%E6%88%91%E7%9A%84%E9%A1%B5/%E8%B5%84%E6%BA%90/%E9%82%80%E8%AF%B7%E6%B4%BB%E5%8A%A802.png" alt="邀请活动图片2" class="card-image" />
            </div>
          </div>
        </div>

        <!-- 叫叫商城模块 -->
        <div class="section mall-section">
          <div class="section-header">
            <span class="section-title">叫叫商城</span>
            <div class="section-link hidden">
              <span class="link-text">邀请奖励记录</span>
              <svg class="link-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M6 4L10 8L6 12" stroke="#acb2bb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
          <div class="card-row">
            <div class="card" style="background-color: #FEF7E5;">
              <img src="https://uiweb.oss-cn-chengdu.aliyuncs.com/img/%E6%88%91%E7%9A%84%E9%A1%B5/%E8%B5%84%E6%BA%90/%E5%95%86%E5%9C%BA1.png" alt="商场图片1" class="card-image" />
            </div>
            <div class="card" style="background-color: #FEF7E5;">
              <img src="https://uiweb.oss-cn-chengdu.aliyuncs.com/img/%E6%88%91%E7%9A%84%E9%A1%B5/%E8%B5%84%E6%BA%90/%E5%95%86%E5%9C%BA2.png" alt="商场图片2" class="card-image" />
            </div>
          </div>
        </div>

        <!-- 底部 Logo -->
        <div class="footer-logo">
          <img src="https://r2-asset-worker.qihaogo.workers.dev/figma/h_e7e211e2.svg" alt="Logo" class="logo-image" />
        </div>

        <!-- 底部广告图 -->
        <div class="bottom-ad">
          <img src="https://r2-asset-worker.qihaogo.workers.dev/figma/h_684bdf65.png" alt="底部广告图" class="ad-image" />
        </div>
      </div>
    </div>

    <!-- 固定顶部导航栏 -->
    <div class="fixed-top-bar">
      <img src="https://r2-asset-worker.qihaogo.workers.dev/figma/h_3b8dd1f6.png" alt="顶部导航栏" class="top-bar-image" />
    </div>

    <!-- 固定底部标签栏 -->
    <div class="fixed-bottom-bar">
      <img src="https://r2-asset-worker.qihaogo.workers.dev/figma/h_684bdf65.png" alt="底部标签栏" class="bottom-bar-image" />
    </div>

  </div>
</body>
</html>
