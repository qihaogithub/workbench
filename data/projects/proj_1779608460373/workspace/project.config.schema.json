{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "学习页活动卡片 - 项目级共享配置",
  "type": "object",
  "properties": {
    "cardImage": {
      "type": "string",
      "format": "image",
      "title": "卡片图片",
      "description": "活动卡片展示图片",
      "default": "https://uiweb.oss-cn-chengdu.aliyuncs.com/img/学习页/top.png"
    },
    "theme": {
      "type": "string",
      "title": "配色方案",
      "description": "卡片配色主题",
      "default": "yellow",
      "enum": ["yellow", "puzzle", "brown", "blue", "green", "purple", "pink", "red", "grassy", "cyan"]
    }
  }
}
