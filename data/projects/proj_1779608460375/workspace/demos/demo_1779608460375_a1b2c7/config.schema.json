{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$demo": {
    "previewSize": {
      "width": 375,
      "height": 812
    }
  },
  "title": "我的页面 - 手机版配置",
  "type": "object",
  "properties": {
    "inviteTitle": {
      "type": "string",
      "title": "邀请活动标题",
      "default": "邀请活动"
    },
    "inviteSubtitle": {
      "type": "string",
      "title": "邀请活动副标题",
      "default": "邀请奖励记录"
    },
    "mallTitle": {
      "type": "string",
      "title": "商场标题",
      "default": "叫叫商场"
    },
    "inviteBgColor1": {
      "type": "string",
      "format": "color",
      "title": "邀请活动背景色1",
      "default": "#ff9045"
    },
    "inviteBgColor2": {
      "type": "string",
      "format": "color",
      "title": "邀请活动背景色2",
      "default": "#ff715c"
    },
    "mallBgColor": {
      "type": "string",
      "format": "color",
      "title": "商场背景色",
      "default": "#fef7e5"
    }
  }
}
