{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$demo": {
    "previewSize": {
      "width": 375,
      "height": 812
    }
  },
  "title": "全屏展示页-第二关已解锁",
  "type": "object",
  "properties": {
    "displayImage": {
      "type": "string",
      "format": "image",
      "title": "展示图片",
      "description": "全屏展示的图片，推荐尺寸 375×812",
      "default": "/api/images/6f9819021808-page.webp",
      "ui:options": {
        "accept": "image/*",
        "maxSize": 10485760,
        "minWidth": 375,
        "minHeight": 812
      }
    },
    "backgroundColor": {
      "type": "string",
      "format": "color",
      "title": "背景色",
      "description": "图片加载前的背景颜色",
      "default": "#000000"
    }
  }
}