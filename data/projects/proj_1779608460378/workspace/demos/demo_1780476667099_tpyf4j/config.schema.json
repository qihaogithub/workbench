{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$demo": {
    "previewSize": {
      "width": 375,
      "height": 812
    }
  },
  "title": "图片展示页 - 手机版配置",
  "type": "object",
  "properties": {
    "displayImage": {
      "type": "string",
      "format": "image",
      "title": "展示图片",
      "description": "请上传或输入图片URL，推荐尺寸 375×812 全屏展示",
      "default": "./images/display-bg.png",
      "ui:options": {
        "accept": "image/*",
        "maxSize": 10485760,
        "minWidth": 375,
        "maxWidth": 750,
        "minHeight": 375,
        "maxHeight": 1624
      }
    },
    "backgroundColor": {
      "type": "string",
      "format": "color",
      "title": "背景色",
      "description": "图片加载前的占位背景色",
      "default": "#ffffff"
    }
  },
  "required": ["displayImage"]
}