{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$demo": {
    "previewSize": { "width": 375, "height": 812 }
  },
  "properties": {
    "displayImage": {
      "type": "string",
      "format": "image",
      "title": "展示图片",
      "description": "全屏展示的图片，推荐尺寸 375×812",
      "default": "./images/#static 背景-4.png",
      "ui:options": {
        "accept": "image/*",
        "maxSize": 5242880,
        "minWidth": 375,
        "minHeight": 812,
        "maxWidth": 375,
        "maxHeight": 812
      }
    },
    "backgroundColor": {
      "type": "string",
      "format": "color",
      "title": "背景色",
      "description": "图片加载前的背景色",
      "default": "#000000"
    }
  }
}