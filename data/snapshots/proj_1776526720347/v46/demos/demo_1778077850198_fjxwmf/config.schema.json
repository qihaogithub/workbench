{
  "type": "object",
  "$demo": {
    "previewSize": {
      "width": "1024px",
      "height": "768px"
    }
  },
  "properties": {
    "pageTitle": {
      "type": "string",
      "title": "页面标题",
      "default": "配置项展示 · 数据内容类",
      "description": "页面顶部的主标题文案"
    },
    "description": {
      "type": "string",
      "title": "描述文字",
      "default": "通过右侧面板调整配置项，实时预览效果。本页演示：文本、数字滑块、开关、下拉选择、数组等配置类型。",
      "description": "标题下方的描述性文字"
    },
    "itemCount": {
      "type": "number",
      "title": "卡片数量",
      "default": 6,
      "minimum": 2,
      "maximum": 16,
      "description": "网格中展示的卡片数量（滑块控制）"
    },
    "showRating": {
      "type": "boolean",
      "title": "显示评分",
      "default": true,
      "description": "是否在卡片上显示星级评分"
    },
    "category": {
      "type": "string",
      "title": "内容分类",
      "enum": ["technology", "nature", "art", "science"],
      "enumNames": ["科技", "自然", "艺术", "科学"],
      "default": "technology",
      "description": "筛选展示不同分类的内容（下拉选择）"
    },
    "tagStyle": {
      "type": "string",
      "title": "标签样式",
      "enum": ["filled", "outlined", "ghost"],
      "enumNames": ["填充标签", "描边标签", "幽灵标签"],
      "default": "filled",
      "description": "分类标签的视觉样式"
    },
    "dataItems": {
      "type": "array",
      "title": "统计数据项",
      "description": "页面底部的统计数据列表（数组配置）",
      "items": {
        "type": "object",
        "properties": {
          "label": { "type": "string", "title": "指标名称" },
          "value": { "type": "number", "title": "指标数值" }
        }
      },
      "default": [
        { "label": "用户数", "value": 12483 },
        { "label": "访问量", "value": 87291 },
        { "label": "转化率", "value": 3.42 },
        { "label": "活跃度", "value": 67 }
      ]
    }
  }
}
