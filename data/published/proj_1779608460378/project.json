  "projectConfigSchema": "{\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n  \"title\": \"广场页面 - 项目级共享配置\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"bigBannerForeground\": {\n      \"type\": \"string\",\n      \"format\": \"image\",\n      \"title\": \"大Banner前景图\",\n      \"description\": \"手机和平板共用的大Banner前景图片，推荐尺寸 1248×384\",\n      \"default\": \"https://uiweb.oss-cn-chengdu.aliyuncs.com/img/广场页/大banner/banner_前景图.png\",\n      \"ui:options\": {\n        \"accept\": \"image/*\",\n        \"maxSize\": 5242880,\n        \"minWidth\": 1248,\n        \"maxWidth\": 1248,\n        \"minHeight\": 384,\n        \"maxHeight\": 384\n      }\n    },\n    \"bigBannerBackground\": {\n      \"type\": \"string\",\n      \"format\": \"image\",\n      \"title\": \"大Banner背景图\",\n      \"description\": \"手机和平板共用的大Banner背景图片，推荐尺寸 1248×344\",\n      \"default\": \"https://uiweb.oss-cn-chengdu.aliyuncs.com/img/广场页/大banner/banner_背景图.png\",\n      \"ui:options\": {\n        \"accept\": \"image/*\",\n        \"maxSize\": 5242880,\n        \"minWidth\": 1248,\n        \"maxWidth\": 1248,\n        \"minHeight\": 344,\n        \"maxHeight\": 344\n      }\n    },\n    \"miniBanners\": {\n      \"type\": \"array\",\n      \"title\": \"小Banner图片列表\",\n      \"description\": \"小Banner滚动区域的图片列表，每张推荐尺寸 480×270\",\n      \"ui:widget\": \"imageList\",\n      \"ui:options\": {\n        \"maxItems\": 10,\n        \"minWidth\": 480,\n        \"maxWidth\": 480,\n        \"minHeight\": 270,\n        \"maxHeight\": 270\n      },\n      \"items\": {\n        \"type\": \"string\",\n        \"format\": \"image\"\n      },\n      \"default\": [\n        \"https://uiweb.oss-cn-chengdu.aliyuncs.com/img/广场页/小banner/Property%201%3D01.png\",\n        \"https://uiweb.oss-cn-chengdu.aliyuncs.com/img/广场页/小banner/Property%201%3D02.png\",\n        \"https://uiweb.oss-cn-chengdu.aliyuncs.com/img/广场页/小banner/Property%201%3D05.png\",\n        \"https://uiweb.oss-cn-chengdu.aliyuncs.com/img/广场页/小banner/Property%201%3D04.png\",\n        \"https://uiweb.oss-cn-chengdu.aliyuncs.com/img/广场页/小banner/Property%201%3D06.png\"\n      ]\n    }\n  }\n}"
