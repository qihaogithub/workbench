      "prototypeHtml": "<div class=\"phone-container\">\n  <!-- 顶部吸顶内容 -->\n  <img class=\"top-bar\" src=\"https://uiweb.oss-cn-chengdu.aliyuncs.com/img/伴读/轮播广告/手机/底部吸顶内容.png\" alt=\"顶部吸顶内容\" />\n\n  <!-- 可滚动内容区域 -->\n  <div class=\"scroll-area\">\n    <div class=\"content-wrapper\">\n      <!-- 重磅更新标题 -->\n      <img class=\"section-title\" src=\"https://uiweb.oss-cn-chengdu.aliyuncs.com/img/伴读/轮播广告/手机/重磅更新标题.png\" alt=\"重磅更新\" />\n\n      <!-- 手机广告图（可配置） -->\n      <img class=\"ad-image\" src=\"https://uiweb.oss-cn-chengdu.aliyuncs.com/img/伴读/轮播广告/手机/一行一个广告图.png\" alt=\"手机广告图\" />\n\n      <!-- 叫叫活动标题 -->\n      <img class=\"section-title\" src=\"https://uiweb.oss-cn-chengdu.aliyuncs.com/img/伴读/轮播广告/手机/叫叫活动标题.png\" alt=\"叫叫活动\" />\n\n      <!-- 轮播广告图容器 -->\n      <div class=\"carousel-container\">\n        <img class=\"carousel-image\" src=\"https://uiweb.oss-cn-chengdu.aliyuncs.com/img/伴读/轮播广告/手机/广告图.png\" alt=\"轮播广告图\" />\n      </div>\n\n      <!-- 底部内容 -->\n      <img class=\"bottom-content\" src=\"https://uiweb.oss-cn-chengdu.aliyuncs.com/img/伴读/轮播广告/手机/下.png\" alt=\"底部内容\" />\n    </div>\n  </div>\n\n  <!-- 底部标签栏 -->\n  <img class=\"bottom-tab-bar\" src=\"https://uiweb.oss-cn-chengdu.aliyuncs.com/img/伴读/轮播广告/手机/吸底标签栏.png\" alt=\"底部标签栏\" />\n</div>",
      "prototypeCss": "/* 手机 - 副本 原型样式 */\n/* 与 React 版保持一致的视觉层级和布局 */\n\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nbody {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  min-height: 100vh;\n  background: #f0f0f0;\n  font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif;\n}\n\n/* 手机容器 */\n.phone-container {\n  position: relative;\n  width: 375px;\n  max-width: 100%;\n  height: 100vh;\n  min-height: 812px;\n  overflow: hidden;\n  background-color: #ffffff;\n  margin: 0 auto;\n}\n\n/* 顶部吸顶内容 */\n.top-bar {\n  position: absolute;\n  left: 0;\n  top: 0;\n  z-index: 20;\n  width: 375px;\n  display: block;\n}\n\n/* 可滚动内容区域 */\n.scroll-area {\n  position: absolute;\n  left: 0;\n  top: 141px;\n  width: 375px;\n  height: 585px;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  overflow-x: hidden;\n  overflow-y: auto;\n  background-color: #ffffff;\n}\n\n/* 隐藏滚动条 - 兼容各浏览器 */\n.scroll-area::-webkit-scrollbar {\n  display: none;\n}\n.scroll-area {\n  -ms-overflow-style: none;\n  scrollbar-width: none;\n}\n\n/* 内容包装器 */\n.content-wrapper {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n}\n\n/* 章节标题图片 */\n.section-title {\n  width: 344px;\n  display: block;\n}\n\n/* 手机广告图 */\n.ad-image {\n  width: 344px;\n  height: 180px;\n  object-fit: cover;\n  display: block;\n}\n\n/* 轮播广告图容器 */\n.carousel-container {\n  width: 344px;\n  height: 180px;\n  flex-shrink: 0;\n  overflow: hidden;\n  border-radius: 10px;\n  background-color: #d9d9d9;\n}\n\n/* 轮播广告图 */\n.carousel-image {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  display: block;\n}\n\n/* 底部内容图片 */\n.bottom-content {\n  width: 375px;\n  flex-shrink: 0;\n  display: block;\n}\n\n/* 底部标签栏 */\n.bottom-tab-bar {\n  position: absolute;\n  bottom: 0;\n  left: 0;\n  z-index: 20;\n  width: 375px;\n  height: 86px;\n  display: block;\n}",
      "prototypeHtmlPath": "demos/page_lib0/prototype.html",
      "prototypeCssPath": "demos/page_lib0/prototype.css"
