{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "圆形知识雷达页配置",
  "type": "object",
  "properties": {
    "orbitTitle": {
      "type": "string",
      "title": "圆形页标题",
      "default": "知识库圆形雷达"
    },
    "centerCode": {
      "type": "string",
      "title": "中心代号",
      "default": "KB-ORION-7421"
    },
    "ringLabel": {
      "type": "string",
      "title": "环形标签",
      "default": "文档事实校准"
    }
  },
  "required": [
    "orbitTitle",
    "centerCode"
  ],
  "$demo": {
    "previewSize": {
      "width": 320,
      "height": 320
    }
  }
}