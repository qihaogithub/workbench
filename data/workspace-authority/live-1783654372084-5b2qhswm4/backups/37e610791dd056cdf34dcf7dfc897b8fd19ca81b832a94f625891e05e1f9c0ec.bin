* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  background: #f5f5f7;
  color: #1d1d1f;
  -webkit-font-smoothing: antialiased;
}

.container {
  max-width: 375px;
  margin: 0 auto;
  min-height: 100vh;
  background: #ffffff;
  position: relative;
  padding-bottom: 72px;
  box-shadow: 0 0 20px rgba(0, 0, 0, 0.05);
}

/* ===== 头部 ===== */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40px 20px 24px;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 0 0 28px 28px;
}

.avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  border: 3px solid rgba(255, 255, 255, 0.6);
  overflow: hidden;
  margin-bottom: 12px;
  background: #e8e8ed;
}

.avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.name {
  font-size: 22px;
  font-weight: 700;
  margin-bottom: 4px;
}

.bio {
  font-size: 14px;
  opacity: 0.85;
}

/* ===== 统计卡片 ===== */
.stats {
  display: flex;
  justify-content: space-around;
  padding: 20px 16px;
  background: #fff;
  margin: -16px 16px 0;
  border-radius: 16px;
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 1;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}

.stat-number {
  font-size: 20px;
  font-weight: 700;
  color: #1d1d1f;
}

.stat-label {
  font-size: 12px;
  color: #86868b;
}

/* ===== 菜单网格 ===== */
.menu-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  padding: 24px 16px 8px;
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 16px 8px;
  background: #f9f9fb;
  border-radius: 14px;
  cursor: pointer;
  transition: transform 0.15s, background 0.15s;
}

.menu-item:hover {
  background: #f0f0f5;
  transform: translateY(-2px);
}

.menu-icon {
  font-size: 28px;
  line-height: 1;
}

.menu-item span {
  font-size: 13px;
  color: #515154;
}

/* ===== 分区标题 ===== */
.section-title {
  padding: 20px 16px 12px;
  font-size: 16px;
  font-weight: 600;
  color: #1d1d1f;
}

/* ===== 动态列表 ===== */
.feed-list {
  display: flex;
  flex-direction: column;
  padding: 0 16px;
  gap: 0;
}

.feed-item {
  display: flex;
  gap: 12px;
  padding: 14px 0;
  border-bottom: 1px solid #f0f0f2;
}

.feed-item:last-child {
  border-bottom: none;
}

.feed-avatar {
  flex-shrink: 0;
}

.feed-avatar-img {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  background: #e8e8ed;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
}

.feed-content {
  flex: 1;
  min-width: 0;
}

.feed-text {
  font-size: 14px;
  line-height: 1.5;
  color: #1d1d1f;
  margin-bottom: 4px;
}

.feed-time {
  font-size: 12px;
  color: #86868b;
}

/* ===== 底部导航 ===== */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100%;
  max-width: 375px;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 8px 0;
  padding-bottom: max(8px, env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-top: 1px solid #f0f0f2;
  z-index: 100;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  cursor: pointer;
  padding: 4px 12px;
}

.nav-icon {
  font-size: 22px;
  line-height: 1;
}

.nav-label {
  font-size: 10px;
  color: #86868b;
}

.nav-item.active .nav-label {
  color: #667eea;
  font-weight: 600;
}
