<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>宝贝学堂 - 儿童教育</title>
  <link rel="stylesheet" href="prototype.css" />
</head>
<body>
  <!-- 顶部状态栏 -->
  <div class="status-bar">
    <span class="time">9:41</span>
    <div class="status-icons">
      <span class="signal">📶</span>
      <span class="wifi">📡</span>
      <span class="battery">🔋</span>
    </div>
  </div>

  <!-- 顶部导航 -->
  <header class="header">
    <button class="menu-btn" aria-label="菜单">☰</button>
    <h1 class="app-title">🌟 宝贝学堂</h1>
    <button class="avatar-btn" aria-label="个人中心">
      <div class="avatar">🐼</div>
    </button>
  </header>

  <!-- 搜索栏 -->
  <div class="search-bar">
    <span class="search-icon">🔍</span>
    <input type="search" placeholder="搜索课程、故事、游戏..." class="search-input" />
  </div>

  <!-- Banner 轮播 -->
  <section class="banner">
    <div class="banner-slide">
      <div class="banner-content">
        <div class="banner-emoji">🎨</div>
        <div class="banner-text">
          <h2>创意美术课</h2>
          <p>激发孩子的想象力</p>
        </div>
      </div>
      <div class="banner-indicator">
        <span class="dot active"></span>
        <span class="dot"></span>
        <span class="dot"></span>
      </div>
    </div>
  </section>

  <!-- 快捷功能 -->
  <section class="quick-actions">
    <div class="action-item">
      <div class="action-icon story">📖</div>
      <span>绘本故事</span>
    </div>
    <div class="action-item">
      <div class="action-icon abc">🔤</div>
      <span>学字母</span>
    </div>
    <div class="action-item">
      <div class="action-icon number">🔢</div>
      <span>学数数</span>
    </div>
    <div class="action-item">
      <div class="action-icon music">🎵</div>
      <span>儿歌</span>
    </div>
    <div class="action-item">
      <div class="action-icon game">🧩</div>
      <span>小游戏</span>
    </div>
  </section>

  <!-- 今日推荐 -->
  <section class="section">
    <div class="section-header">
      <h3>📚 今日推荐</h3>
      <button class="more-btn">更多 ›</button>
    </div>
    <div class="recommend-list">
      <div class="course-card">
        <div class="card-thumb thumb-abc"></div>
        <div class="card-body">
          <h4>🎯 趣味拼音</h4>
          <p>认识声母韵母，快乐学拼音</p>
          <div class="card-meta">
            <span class="tag">3-6岁</span>
            <span class="duration">12节</span>
          </div>
        </div>
      </div>
      <div class="course-card">
        <div class="card-thumb thumb-math"></div>
        <div class="card-body">
          <h4>🧮 数学启蒙</h4>
          <p>1-100数字认知与简单加减</p>
          <div class="card-meta">
            <span class="tag">4-7岁</span>
            <span class="duration">15节</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 热门课程 -->
  <section class="section">
    <div class="section-header">
      <h3>🔥 热门课程</h3>
      <button class="more-btn">全部 ›</button>
    </div>
    <div class="course-grid">
      <div class="grid-card">
        <div class="grid-emoji">🌍</div>
        <span>探索世界</span>
      </div>
      <div class="grid-card">
        <div class="grid-emoji">🎨</div>
        <span>创意绘画</span>
      </div>
      <div class="grid-card">
        <div class="grid-emoji">🐯</div>
        <span>动物世界</span>
      </div>
      <div class="grid-card">
        <div class="grid-emoji">🚀</div>
        <span>太空探险</span>
      </div>
    </div>
  </section>

  <!-- 底部导航 -->
  <nav class="bottom-nav">
    <div class="nav-item active">
      <span class="nav-icon">🏠</span>
      <span class="nav-label">首页</span>
    </div>
    <div class="nav-item">
      <span class="nav-icon">📚</span>
      <span class="nav-label">课程</span>
    </div>
    <div class="nav-item">
      <span class="nav-icon">🎬</span>
      <span class="nav-label">动画</span>
    </div>
    <div class="nav-item">
      <span class="nav-icon">👤</span>
      <span class="nav-label">我的</span>
    </div>
  </nav>
</body>
</html>