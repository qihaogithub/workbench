<svg xmlns="http://www.w3.org/2000/svg" width="420" height="104" viewBox="0 0 420 104" role="img" aria-labelledby="title desc">
  <title id="title">为你喜欢的球队助威</title>
  <desc id="desc">选择支持的球队，为ta贡献人气</desc>
  <defs>
    <linearGradient id="mainText" x1="16" y1="14" x2="330" y2="60" gradientUnits="userSpaceOnUse">
      <stop offset="0" stop-color="#ffffff"/>
      <stop offset="0.56" stop-color="#fff7c5"/>
      <stop offset="1" stop-color="#ffd447"/>
    </linearGradient>
    <linearGradient id="subText" x1="18" y1="67" x2="240" y2="87" gradientUnits="userSpaceOnUse">
      <stop offset="0" stop-color="#e6ffef"/>
      <stop offset="1" stop-color="#bfffe0"/>
    </linearGradient>
    <filter id="textShadow" x="-8%" y="-35%" width="116%" height="180%">
      <feDropShadow dx="0" dy="3" stdDeviation="2.5" flood-color="#022417" flood-opacity="0.52"/>
      <feDropShadow dx="0" dy="9" stdDeviation="8" flood-color="#022417" flood-opacity="0.32"/>
    </filter>
  </defs>
  <g filter="url(#textShadow)">
    <text x="0" y="42" fill="url(#mainText)" font-family="PingFang SC, Microsoft YaHei, sans-serif" font-size="32" font-weight="950">为你喜欢的球队助威</text>
    <text x="2" y="78" fill="url(#subText)" font-family="PingFang SC, Microsoft YaHei, sans-serif" font-size="18" font-weight="800">选择支持的球队，为ta贡献人气</text>
  </g>
  <path d="M0 94H314" stroke="#ffd447" stroke-width="5" stroke-linecap="round" opacity="0.9"/>
  <path d="M0 94H186" stroke="#ffffff" stroke-width="2" stroke-linecap="round" opacity="0.82"/>
</svg>
