<main class="wc-page is-dim">
  <img class="hero-title" src="../../assets/football/home/hero-title-figma.webp" alt="叫叫阅读足球季，为球队助威">
  <section class="win-card" aria-label="抽奖结果">
    <h1>恭喜获得</h1>
    <div class="certificate">
      <img src="../../assets/football/prize-plush-card.webp" alt="足球冠军叫叫公仔">
      <h2>足球冠军叫叫公仔</h2>
      <p>实物奖品需填写收货地址后发放。</p>
    </div>
    <div class="win-actions"><button class="white-btn">稍后再说</button><button class="yellow-btn">立即领取</button></div>
  </section>
</main>
