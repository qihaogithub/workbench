<main class="wc-page is-dim">
  <img class="hero-title" src="../../assets/football/home/hero-title-figma.webp" alt="叫叫阅读足球季，为球队助威">
  <section class="preview-wrap" aria-label="奖品预览">
    <div class="preview-card">
      <img src="../../assets/football/champion-skin-card.webp" alt="叫叫冠军皮肤装扮">
      <h1>叫叫冠军皮肤装扮</h1>
      <p>冠军达标奖励，活动结束后可查看。</p>
    </div>
    <button class="preview-close" aria-label="关闭"></button>
  </section>
</main>
