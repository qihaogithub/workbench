/* prototype.css — demo - 副本 (demo_71dt) */
/* 完全内联样式，无远程依赖，无全局选择器 */

.prototype-root,
.prototype-root *,
.prototype-root *::before,
.prototype-root *::after {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

.prototype-root {
  width: 100%;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e8e8e8;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

/* 手机容器 */
.phone-frame {
  width: 375px;
  height: 812px;
  position: relative;
  background: #ffffff;
  border-radius: 24px;
  overflow: hidden;
  flex-shrink: 0;
}

/* 可滑动内容区域 */
.scroll-area {
  position: absolute;
  inset: 0;
  overflow-y: auto;
  overflow-x: hidden;
}

/* 隐藏滚动条 */
.scroll-area::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
}
.scroll-area {
  -ms-overflow-style: none;
  scrollbar-width: none;
}

/* 主视觉图 */
.hero-image {
  display: block;
  width: 335px;
  height: 455px;
  object-fit: cover;
  margin: 44px auto 0;
}

/* 通用模块 */
.section {
  width: 335px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14px;
}

.section-invite {
  margin-top: 14px;
}

.section-mall {
  margin-top: 14px;
}

/* 模块头部 */
.section-header {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;
  padding-bottom: 14px;
}

.section-title {
  color: #3f3f3f;
  font-size: 18px;
  font-weight: 500;
  line-height: 27px;
  white-space: nowrap;
  flex-shrink: 0;
}

.section-mall .section-title {
  color: #666666;
}

.section-more {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  flex-shrink: 0;
  gap: 4px;
  padding-right: 4px;
}

.section-more-hidden {
  display: none;
}

.more-text {
  color: #acb2bb;
  font-size: 12px;
  font-weight: 400;
  line-height: 18px;
  text-align: right;
  white-space: nowrap;
}

.more-icon {
  width: 16px;
  height: 16px;
  object-fit: cover;
}

/* 卡片行 */
.card-row {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
}

.card {
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border-radius: 16px;
  flex: 1;
  height: 64px;
  max-width: 163.5px;
}

.card:last-child {
  height: 62px;
}

.card img {
  height: 100%;
  width: auto;
  object-fit: contain;
}

/* 底部客服信息 */
.footer-contact {
  width: 335px;
  margin: 0 auto;
  padding: 24px 10px;
  display: inline-flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  gap: 10px;
  margin-top: 140px;
}

.contact-phone {
  width: 159px;
  height: 45px;
  position: relative;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  gap: 4px;
}

.phone-icon {
  width: 20px;
  height: 20px;
  display: block;
}

.phone-number {
  color: #abb2bb;
  font-size: 14px;
  font-weight: 400;
  font-family: "FZLanTingYuan-DB-GBK", -apple-system, sans-serif;
  line-height: 16px;
  white-space: nowrap;
  margin-top: 2px;
}

.contact-hours {
  color: #abb2bb;
  font-size: 14px;
  font-weight: 400;
  font-family: "FZLanTingYuan-R-GBK", -apple-system, sans-serif;
  text-align: center;
  white-space: nowrap;
}

/* 固定顶部导航栏 */
.fixed-top-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  pointer-events: none;
}

.fixed-top-bar img {
  width: 100%;
  height: 44px;
  object-fit: cover;
  display: block;
}

/* 固定底部标签栏 */
.fixed-bottom-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 10;
  pointer-events: none;
}

.fixed-bottom-bar img {
  width: 100%;
  height: 90px;
  object-fit: cover;
  display: block;
}
