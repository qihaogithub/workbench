ngFang SC\", sans-serif' }}\n                >\n                  {mainButtonText}\n                </span>\n              </div>\n              <span\n                className=\"text-[#666] text-center text-lg font-normal leading-[150%] cursor-pointer\"\n                style={{ fontFamily: '\"PingFang SC\", sans-serif' }}\n              >\n                {secondaryButtonText}\n              </span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}\n","expectedHash":"98e010c7971991145b0641108ce28ffb99773bbdb2b9aed5085c67b99d257869"},{"type":"put_text","path":"demos/demo_1779608460501_abc123/config.schema.json","content":"{\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n  \"$demo\": {\n    \"previewSize\": {\n      \"width\": 375,\n      \"height\": 812\n    }\n  },\n  \"title\": \"底部弹窗 - 手机版配置\",\n  \"type\": \"object\",\n  \"properties\": {}\n}\n","expectedHash":"ca09ae46d14bca062c8e68c1cb6bb599f545e6100a9f87b34c5b1ca4287d4b4d"},{"type":"put_text","path":"demos/demo_1779608460501_abc123/prototype.html","content":"<div class=\"phone-popup-container\">\n  <div class=\"phone-popup-bg\"></div>\n  <div class=\"phone-popup-overlay\">\n    <div class=\"phone-popup-content\">\n      <img\n        class=\"phone-popup-image\"\n        src=\"/api/images/7ff9e09eafad-popup-image.png\"\n        alt=\"\"\n        data-bind-src=\"popupImage\"\n      />\n      <div class=\"phone-popup-actions\">\n        <div class=\"phone-popup-button\" data-bind-text=\"mainButtonText\">去看看</div>\n        <span class=\"phone-popup-secondary\" data-bind-text=\"secondaryButtonText\">下次再说</span>\n      </div>\n    </div>\n  </div>\n</div>\n","expectedHash":"cb3a191179d4c3a0a3feb8c90639c1ebcdac7e301e5a93dd678514600fd9a71e"},{"type":"put_text","path":"demos/demo_1779608460501_abc123/prototype.css","content":"/* 手机底部广告弹窗 - HTML/CSS 原型 */\n.phone-popup-container {\n  position: relative;\n  width: 100%;\n  height: 100vh;\n  max-width: 375px;\n