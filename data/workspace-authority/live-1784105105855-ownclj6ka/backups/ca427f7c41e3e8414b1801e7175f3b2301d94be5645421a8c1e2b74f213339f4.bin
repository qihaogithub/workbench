/* ==================== 品牌展示页原型 CSS ==================== */
/* 颜色变量 — 可通过 data-bind-style-* 覆盖 */
:root {
  --primary-color: #4F46E5;
  --accent-color: #F59E0B;
  --brand-name: '星辰科技';
}

/* ==================== 全局重置 ==================== */
*,
*::before,
*::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Noto Sans SC', sans-serif;
  background-color: #ffffff;
  color: #111827;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

a {
  color: inherit;
  text-decoration: none;
}

/* ==================== 导航栏 ==================== */
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  background-color: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid #f3f4f6;
}

.navbar-inner {
  max-width: 1152px;
  margin: 0 auto;
  padding: 0 24px;
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.brand {
  display: flex;
  align-items: center;
  gap: 8px;
}

.brand-logo {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--primary-color);
}

.brand-initial {
  color: #ffffff;
  font-size: 14px;
  font-weight: 700;
}

.brand-name {
  font-weight: 600;
  color: #111827;
}

.nav-links {
  display: flex;
  align-items: center;
  gap: 24px;
  font-size: 14px;
  color: #6b7280;
}

.nav-links a:hover {
  color: #111827;
  transition: color 0.2s;
}

/* ==================== Hero 区域 ==================== */
.hero-section {
  padding-top: 128px;
  padding-bottom: 80px;
  padding-left: 24px;
  padding-right: 24px;
  position: relative;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  inset: 0;
  opacity: 0.05;
  background:
    radial-gradient(circle at 20% 50%, var(--primary-color) 0%, transparent 50%),
    radial-gradient(circle at 80% 50%, var(--accent-color) 0%, transparent 50%);
}

.hero-content {
  max-width: 896px;
  margin: 0 auto;
  text-align: center;
  position: relative;
}

.slogan-badge {
  display: inline-block;
  font-size: 12px;
  font-weight: 500;
  padding: 4px 16px;
  border-radius: 9999px;
  margin-bottom: 24px;
  background-color: rgba(79, 70, 229, 0.063);
  color: var(--primary-color);
}

.hero-title {
  font-size: 36px;
  font-weight: 700;
  color: #111827;
  line-height: 1.2;
  margin-bottom: 24px;
}

.hero-subtitle {
  font-size: 18px;
  color: #6b7280;
  max-width: 576px;
  margin: 0 auto 40px;
  line-height: 1.625;
}

.hero-cta {
  display: inline-block;
  color: #ffffff;
  padding: 14px 32px;
  border-radius: 12px;
  font-weight: 500;
  font-size: 16px;
  border: none;
  cursor: pointer;
  background-color: var(--primary-color);
  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
  transition: all 0.2s;
}

.hero-cta:hover {
  box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
  transform: translateY(-2px);
}

/* ==================== 特色区域 ==================== */
.features-section {
  padding: 80px 24px;
  background-color: #f9fafb;
}

.features-inner {
  max-width: 1152px;
  margin: 0 auto;
}

.features-title {
  font-size: 30px;
  font-weight: 700;
  text-align: center;
  color: #111827;
  margin-bottom: 16px;
}

.features-desc {
  color: #6b7280;
  text-align: center;
  margin-bottom: 56px;
  max-width: 320px;
  margin-left: auto;
  margin-right: auto;
}

.features-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 24px;
}

/* 特色卡片 */
.feature-card {
  background-color: #ffffff;
  border-radius: 16px;
  padding: 24px;
  border: 1px solid #f3f4f6;
  transition: all 0.2s;
}

.feature-card:hover {
  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
  transform: translateY(-4px);
}

.feature-icon {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
  background-color: rgba(79, 70, 229, 0.063);
  color: var(--primary-color);
}

.icon-svg {
  width: 24px;
  height: 24px;
}

.feature-title {
  font-weight: 600;
  color: #111827;
  margin-bottom: 8px;
}

.feature-desc {
  font-size: 14px;
  color: #6b7280;
  line-height: 1.625;
}

/* ==================== CTA 区域 ==================== */
.cta-section {
  padding: 80px 24px;
}

.cta-inner {
  max-width: 896px;
  margin: 0 auto;
  border-radius: 24px;
  padding: 48px;
  text-align: center;
  color: #ffffff;
  background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
}

.cta-title {
  font-size: 30px;
  font-weight: 700;
  margin-bottom: 16px;
}

.cta-desc {
  color: rgba(255, 255, 255, 0.8);
  font-size: 18px;
  margin-bottom: 32px;
  max-width: 384px;
  margin-left: auto;
  margin-right: auto;
}

.cta-button {
  background-color: #ffffff;
  color: #111827;
  padding: 14px 32px;
  border-radius: 12px;
  font-weight: 500;
  font-size: 16px;
  border: none;
  cursor: pointer;
  transition: all 0.2s;
}

.cta-button:hover {
  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
}

/* ==================== 页脚 ==================== */
.page-footer {
  border-top: 1px solid #f3f4f6;
  padding: 32px 24px;
  text-align: center;
  font-size: 14px;
  color: #9ca3af;
}

/* ==================== 响应式 ==================== */

/* 平板 (md) */
@media (min-width: 768px) {
  .hero-title {
    font-size: 48px;
  }

  .hero-subtitle {
    font-size: 20px;
  }

  .features-title {
    font-size: 36px;
  }

  .features-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .cta-title {
    font-size: 36px;
  }

  .cta-inner {
    padding: 64px;
  }
}

/* 桌面 (lg) */
@media (min-width: 1024px) {
  .hero-title {
    font-size: 60px;
  }

  .features-grid {
    grid-template-columns: repeat(4, 1fr);
  }
}