<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>时间到</title>
  <link rel="stylesheet" href="prototype.css">
</head>
<body>
  <div class="page">
    <!-- 失败主视觉 -->
    <div class="fail-hero">
      <div class="fail-icon">⏰</div>
      <div class="fail-title">时间到！</div>
      <div class="fail-sub">别灰心，再试一次吧</div>
    </div>

    <!-- 正确答案展示 -->
    <div class="answer-card">
      <div class="answer-label">正确答案</div>
      <div class="answer-word">马</div>
      <div class="answer-pinyin">mǎ</div>
    </div>

    <!-- 当前进度 -->
    <div class="fail-progress">
      <div class="progress-row">
        <span class="progress-text">当前进度</span>
        <span class="progress-value">第 3 关 / 共 5 关</span>
      </div>
      <div class="progress-track">
        <div class="progress-fill" style="width:40%"></div>
      </div>
    </div>

    <!-- 叫叫鼓励 -->
    <div class="encourage-bubble">
      <div class="mascot-mini">
        <div class="mini-face">
          <div class="mini-eye left"></div>
          <div class="mini-eye right"></div>
          <div class="mini-beak"></div>
        </div>
      </div>
      <div class="bubble-text">加油！你可以的 💪</div>
    </div>

    <!-- 按钮 -->
    <div class="fail-actions">
      <button class="btn-retry">
        <span>再试一次</span>
      </button>
      <button class="btn-back">返回首页</button>
    </div>
  </div>
</body>
</html>
