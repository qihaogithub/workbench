<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>挑战完成</title>
  <link rel="stylesheet" href="prototype.css">
</head>
<body>
  <div class="page">
    <!-- 烟花背景装饰 -->
    <div class="confetti c1"></div>
    <div class="confetti c2"></div>
    <div class="confetti c3"></div>
    <div class="confetti c4"></div>
    <div class="confetti c5"></div>
    <div class="confetti c6"></div>
    <div class="confetti c7"></div>
    <div class="confetti c8"></div>

    <!-- 顶部标题 -->
    <div class="result-header">
      <div class="header-badge">🎉 挑战完成</div>
      <h1 class="header-title">太棒了！</h1>
    </div>

    <!-- 评级徽章 -->
    <div class="rank-badge">
      <div class="rank-medal">
        <span class="medal-icon">🏅</span>
      </div>
      <div class="rank-name">识字小达人</div>
      <div class="rank-score">
        <span class="score-big">480</span>
        <span class="score-unit">分</span>
      </div>
    </div>

    <!-- 关卡回顾 -->
    <div class="review-section">
      <div class="review-title">关卡回顾</div>
      <div class="review-list">
        <!-- 关卡1 - 正确 -->
        <div class="review-item correct">
          <div class="review-num">01</div>
          <div class="review-info">
            <div class="review-name">残影猜字 · 「大」</div>
            <div class="review-time">用时 3.2s</div>
          </div>
          <div class="review-badge-item">✓</div>
        </div>
        <!-- 关卡2 - 正确 -->
        <div class="review-item correct">
          <div class="review-num">02</div>
          <div class="review-info">
            <div class="review-name">笔画拼字 · 「人」</div>
            <div class="review-time">用时 5.8s</div>
          </div>
          <div class="review-badge-item">✓</div>
        </div>
        <!-- 关卡3 - 正确 -->
        <div class="review-item correct">
          <div class="review-num">03</div>
          <div class="review-info">
            <div class="review-name">残影猜字 · 「家」</div>
            <div class="review-time">用时 2.1s</div>
          </div>
          <div class="review-badge-item">✓</div>
        </div>
        <!-- 关卡4 - 正确 -->
        <div class="review-item correct">
          <div class="review-num">04</div>
          <div class="review-info">
            <div class="review-name">笔画拼字 · 「马」</div>
            <div class="review-time">用时 6.5s</div>
          </div>
          <div class="review-badge-item">✓</div>
        </div>
        <!-- 关卡5 - 正确 -->
        <div class="review-item correct">
          <div class="review-num">05</div>
          <div class="review-info">
            <div class="review-name">残影猜字 · 「山」</div>
            <div class="review-time">用时 1.8s</div>
          </div>
          <div class="review-badge-item">✓</div>
        </div>
      </div>
    </div>

    <!-- 操作按钮 -->
    <div class="result-actions">
      <button class="btn-share">
        <span class="share-icon">📤</span>
        <span>分享战绩</span>
      </button>
      <button class="btn-retry">
        <span>再来一次</span>
      </button>
    </div>

    <!-- 底部品牌 -->
    <div class="result-footer">
      <span class="footer-icon">🐔</span>
      <span>叫叫 · 汉字大冒险</span>
    </div>
  </div>
</body>
</html>
