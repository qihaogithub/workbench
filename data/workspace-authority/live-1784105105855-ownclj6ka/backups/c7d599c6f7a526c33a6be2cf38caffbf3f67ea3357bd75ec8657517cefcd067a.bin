<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>汉字大冒险</title>
  <link rel="stylesheet" href="prototype.css">
</head>
<body>
  <div class="page">
    <!-- 浮动装饰球 -->
    <div class="bg-orb bg-orb-1"></div>
    <div class="bg-orb bg-orb-2"></div>
    <div class="bg-orb bg-orb-3"></div>

    <!-- 顶部品牌 -->
    <div class="brand">
      <span class="brand-icon">🐔</span>
      <span class="brand-name">叫叫</span>
    </div>

    <!-- 主视觉区 -->
    <div class="hero">
      <!-- 叫叫IP形象区 -->
      <div class="mascot">
        <div class="mascot-body">
          <div class="mascot-face">
            <div class="mascot-eye left"></div>
            <div class="mascot-eye right"></div>
            <div class="mascot-beak"></div>
            <div class="mascot-comb"></div>
          </div>
          <div class="mascot-wing left"></div>
          <div class="mascot-wing right"></div>
        </div>
        <div class="mascot-speech">
          <span>来挑战吧！</span>
        </div>
      </div>

      <!-- 标题 -->
      <div class="title-block">
        <h1 class="title-main">
          <span class="char char-1" style="animation-delay:0.25s">汉</span>
          <span class="char char-2" style="animation-delay:0.33s">字</span>
          <span class="char char-3" style="animation-delay:0.41s">大</span>
          <span class="char char-4" style="animation-delay:0.49s">冒</span>
          <span class="char char-5" style="animation-delay:0.57s">险</span>
        </h1>
        <p class="title-sub">残影猜字 · 笔画拼字 · 双重挑战</p>
      </div>
    </div>

    <!-- 玩法亮点卡片 -->
    <div class="features">
      <div class="feature-card">
        <div class="feature-icon">🔍</div>
        <div class="feature-title">残影猜字</div>
        <div class="feature-desc">从残缺笔画中<br>猜出完整汉字</div>
      </div>
      <div class="feature-divider"></div>
      <div class="feature-card">
        <div class="feature-icon">🧩</div>
        <div class="feature-title">笔画拼字</div>
        <div class="feature-desc">把散落笔画<br>拼成正确汉字</div>
      </div>
    </div>

    <!-- 开始按钮 -->
    <button class="btn-start">
      <span class="btn-text">开始挑战</span>
      <span class="btn-arrow">→</span>
    </button>

    <!-- 底部信息 -->
    <div class="footer-info">
      <p>共 5 关 · 限时挑战 · 看看你能闯到第几关</p>
      <p class="footer-hint">叫叫 × 汉字大冒险</p>
    </div>
  </div>
</body>
</html>
