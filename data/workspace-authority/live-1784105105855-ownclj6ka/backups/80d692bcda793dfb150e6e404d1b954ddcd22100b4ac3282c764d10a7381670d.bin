<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>品牌展示页</title>
  <link rel="stylesheet" href="prototype.css" />
</head>
<body>
  <div class="page-wrapper">

    <!-- 导航栏 -->
    <header class="navbar">
      <div class="navbar-inner">
        <div class="brand">
          <div class="brand-logo" data-bind-style-background-color="primaryColor">
            <span class="brand-initial">星</span>
          </div>
          <span class="brand-name" data-bind-text="brandName">星辰科技</span>
        </div>
        <nav class="nav-links">
          <a href="#">首页</a>
          <a href="#">产品</a>
          <a href="#">关于</a>
        </nav>
      </div>
    </header>

    <!-- Hero 区域 -->
    <section class="hero-section">
      <div class="hero-bg"></div>
      <div class="hero-content">
        <span class="slogan-badge" data-bind-text="companySlogan" data-bind-style-color="primaryColor" data-bind-style-background-color="primaryColor" style="display:none;">星辰科技</span>
        <h1 class="hero-title" data-bind-text="heroTitle">创新科技，智造未来</h1>
        <p class="hero-subtitle" data-bind-text="heroSubtitle">我们致力于通过前沿技术，为企业提供智能化解决方案，助力数字化转型</p>
        <button class="hero-cta" data-bind-text="ctaLabel" data-bind-style-background-color="primaryColor">了解详情</button>
      </div>
    </section>

    <!-- 特色区域 -->
    <section class="features-section">
      <div class="features-inner">
        <h2 class="features-title" data-bind-text="featuresTitle">核心优势</h2>
        <p class="features-desc">全方位满足您的业务需求</p>
        <div class="features-grid">
          <!-- 极速响应 -->
          <div class="feature-card">
            <div class="feature-icon">
              <svg class="icon-svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
              </svg>
            </div>
            <h3 class="feature-title">极速响应</h3>
            <p class="feature-desc">毫秒级响应速度，保证用户体验流畅无阻</p>
          </div>
          <!-- 安全可靠 -->
          <div class="feature-card">
            <div class="feature-icon">
              <svg class="icon-svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
              </svg>
            </div>
            <h3 class="feature-title">安全可靠</h3>
            <p class="feature-desc">多重加密防护，数据安全无忧</p>
          </div>
          <!-- 全球覆盖 -->
          <div class="feature-card">
            <div class="feature-icon">
              <svg class="icon-svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 9.749c0 2.523-.59 4.995-1.757 7.254m0 0A11.96 11.96 0 0112 21" />
              </svg>
            </div>
            <h3 class="feature-title">全球覆盖</h3>
            <p class="feature-desc">遍布全球的节点网络，稳定可靠</p>
          </div>
          <!-- 智能驱动 -->
          <div class="feature-card">
            <div class="feature-icon">
              <svg class="icon-svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
              </svg>
            </div>
            <h3 class="feature-title">智能驱动</h3>
            <p class="feature-desc">AI 驱动的智能决策，让效率翻倍</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA 底部 -->
    <section class="cta-section">
      <div class="cta-inner">
        <h2 class="cta-title">准备好开始了吗？</h2>
        <p class="cta-desc">加入数千家信任我们的企业，开启智能转型之旅</p>
        <button class="cta-button">免费试用</button>
      </div>
    </section>

    <!-- 页脚 -->
    <footer class="page-footer">
      <p>&copy; 2026 星辰科技. All rights reserved.</p>
    </footer>

  </div>
</body>
</html><!DOCTYPE html>
