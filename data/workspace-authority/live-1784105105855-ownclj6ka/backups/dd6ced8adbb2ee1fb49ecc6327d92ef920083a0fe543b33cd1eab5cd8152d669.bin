/* ===== 活动入口页 - 美化版 ===== */
* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: 'Noto Serif SC', 'PingFang SC', 'Microsoft YaHei', serif;
  background: #1a1410;
  overflow-x: hidden;
}

.page {
  position: relative;
  min-height: 100vh;
  max-width: 480px;
  margin: 0 auto;
  background: linear-gradient(180deg, #fef7e8 0%, #fdf0d5 30%, #fbe8c0 60%, #f5d89a 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 24px 40px;
  overflow: hidden;
}

/* 浮动装饰球 */
.bg-orb {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}
.bg-orb-1 {
  width: 180px; height: 180px;
  background: radial-gradient(circle, rgba(212,168,83,0.12) 0%, transparent 70%);
  top: 5%; right: -40px;
  animation: floatOrb 7s ease-in-out infinite;
}
.bg-orb-2 {
  width: 140px; height: 140px;
  background: radial-gradient(circle, rgba(197,61,61,0.08) 0%, transparent 70%);
  bottom: 25%; left: -30px;
  animation: floatOrb 8s ease-in-out infinite 1s;
}
.bg-orb-3 {
  width: 100px; height: 100px;
  background: radial-gradient(circle, rgba(212,168,83,0.1) 0%, transparent 70%);
  top: 50%; right: -20px;
  animation: floatOrb 6s ease-in-out infinite 2s;
}

@keyframes floatOrb {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-18px) scale(1.05); }
}

/* 品牌 */
.brand {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 16px 0;
  width: 100%;
  justify-content: center;
  position: relative;
  z-index: 1;
  animation: fadeInDown 0.5s ease both;
}
.brand-icon { font-size: 28px; }
.brand-name {
  font-size: 18px;
  font-weight: 700;
  color: #8b4513;
  letter-spacing: 2px;
}

/* 叫叫IP */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24px;
  margin-top: 8px;
  width: 100%;
  position: relative;
  z-index: 1;
  animation: fadeInUp 0.6s ease 0.1s both;
}

.mascot {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: breathe 3s ease-in-out infinite 0.5s;
}

.mascot-body {
  position: relative;
  width: 100px;
  height: 110px;
}

.mascot-face {
  position: absolute;
  width: 80px;
  height: 70px;
  background: linear-gradient(180deg, #ff6b35 0%, #e85d2c 100%);
  border-radius: 50% 50% 45% 45%;
  top: 0;
  left: 10px;
  border: 3px solid #c44220;
  box-shadow: 0 4px 12px rgba(196,66,32,0.25);
}

.mascot-eye {
  position: absolute;
  width: 14px;
  height: 16px;
  background: #fff;
  border-radius: 50%;
  top: 22px;
}
.mascot-eye.left { left: 18px; }
.mascot-eye.right { right: 18px; }

.mascot-eye::after {
  content: '';
  position: absolute;
  width: 6px;
  height: 8px;
  background: #1a1410;
  border-radius: 50%;
  top: 4px;
  left: 4px;
}

.mascot-beak {
  position: absolute;
  width: 0;
  height: 0;
  border-left: 8px solid transparent;
  border-right: 8px solid transparent;
  border-top: 10px solid #ffa500;
  top: 38px;
  left: 32px;
}

.mascot-comb {
  position: absolute;
  width: 24px;
  height: 18px;
  background: #e82c2c;
  border-radius: 50% 50% 0 0;
  top: -12px;
  left: 28px;
}

.mascot-wing {
  position: absolute;
  width: 36px;
  height: 50px;
  background: #ff8c5a;
  border-radius: 50%;
  top: 30px;
  border: 2px solid #c44220;
}
.mascot-wing.left {
  left: -16px;
  transform: rotate(-20deg);
}
.mascot-wing.right {
  right: -16px;
  transform: rotate(20deg);
}

/* 对话气泡 */
.mascot-speech {
  position: absolute;
  top: -40px;
  right: -60px;
  background: #fff;
  border: 2px solid #e0c9a6;
  border-radius: 16px;
  padding: 8px 14px;
  font-size: 14px;
  color: #8b4513;
  font-weight: 600;
  box-shadow: 0 4px 16px rgba(0,0,0,0.08);
  white-space: nowrap;
  animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) 0.6s both;
}
.mascot-speech::after {
  content: '';
  position: absolute;
  bottom: -8px;
  left: 30px;
  width: 0; height: 0;
  border-left: 8px solid transparent;
  border-right: 8px solid transparent;
  border-top: 8px solid #fff;
}

/* 标题 */
.title-block {
  text-align: center;
  animation: fadeInUp 0.6s ease 0.2s both;
}

.title-main {
  display: flex;
  justify-content: center;
  gap: 8px;
  margin-bottom: 12px;
}

.char {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 54px;
  height: 66px;
  font-size: 42px;
  font-weight: 900;
  color: #3c1f0e;
  background: linear-gradient(180deg, #fdf5e0 0%, #f5deb0 100%);
  border: 2px solid #d4a853;
  border-radius: 10px;
  box-shadow: 0 3px 0 #b8943e, 0 6px 16px rgba(60,31,14,0.12);
  text-shadow: 0 2px 0 rgba(180,140,80,0.25), 0 1px 2px rgba(60,31,14,0.1);
  animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) both;
}

.title-sub {
  font-size: 15px;
  color: #a0522d;
  letter-spacing: 2px;
  font-weight: 500;
  animation: fadeInUp 0.5s ease 0.6s both;
}

/* 玩法卡片 */
.features {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-top: 36px;
  padding: 24px 20px;
  background: rgba(255,255,255,0.65);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-radius: 20px;
  border: 1.5px solid rgba(212,184,150,0.5);
  box-shadow: 0 8px 32px rgba(60,31,14,0.08);
  width: 100%;
  position: relative;
  z-index: 1;
  animation: fadeInUp 0.6s ease 0.4s both;
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.25s ease;
}
.features:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 40px rgba(60,31,14,0.14);
}

.feature-card {
  flex: 1;
  text-align: center;
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.feature-card:hover {
  transform: translateY(-4px) scale(1.03);
}
.feature-icon {
  font-size: 40px;
  margin-bottom: 10px;
  filter: drop-shadow(0 2px 4px rgba(0,0,0,0.08));
  transition: transform 0.3s ease;
}
.feature-card:hover .feature-icon {
  transform: scale(1.15);
}
.feature-title {
  font-size: 16px;
  font-weight: 700;
  color: #3c1f0e;
  margin-bottom: 6px;
}
.feature-desc {
  font-size: 12px;
  color: #8b7355;
  line-height: 1.6;
}

.feature-divider {
  width: 2px;
  height: 60px;
  background: linear-gradient(180deg, transparent, #e0c9a6, transparent);
  border-radius: 1px;
}

/* 开始按钮 */
.btn-start {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 230px;
  height: 58px;
  margin-top: 36px;
  background: linear-gradient(180deg, #e04545 0%, #c53030 100%);
  border: none;
  border-radius: 29px;
  box-shadow: 0 4px 0 #a02020, 0 6px 24px rgba(192,48,48,0.35), 0 0 40px rgba(224,69,69,0.12);
  cursor: pointer;
  transition: transform 0.15s, box-shadow 0.15s;
  position: relative;
  z-index: 1;
  animation: fadeInUp 0.6s ease 0.5s both;
  overflow: hidden;
}

.btn-start::after {
  content: '';
  position: absolute;
  top: 0; left: -100%;
  width: 60%; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  transform: skewX(-20deg);
  animation: shimmerBtn 3s ease-in-out infinite;
}

.btn-start:active {
  transform: translateY(3px);
  box-shadow: 0 1px 0 #a02020, 0 3px 16px rgba(192,48,48,0.25);
}

.btn-text {
  font-size: 20px;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2px;
  position: relative;
  z-index: 1;
}
.btn-arrow {
  font-size: 20px;
  color: #ffd700;
  font-weight: 700;
  position: relative;
  z-index: 1;
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.btn-start:hover .btn-arrow {
  transform: translateX(5px);
}

/* 底部 */
.footer-info {
  margin-top: 36px;
  text-align: center;
  position: relative;
  z-index: 1;
  animation: fadeInUp 0.5s ease 0.7s both;
}
.footer-info p {
  font-size: 13px;
  color: #b8946e;
  line-height: 1.8;
}
.footer-hint {
  font-size: 11px !important;
  color: #d4b896 !important;
  margin-top: 4px;
}

/* ===== Keyframes ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeInDown {
  from { opacity: 0; transform: translateY(-15px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes popIn {
  from { transform: scale(0.5); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}
@keyframes breathe {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6px); }
}
@keyframes shimmerBtn {
  0%, 100% { left: -100%; }
  50% { left: 150%; }
}
