{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$demo": {
    "previewSize": {
      "width": 375,
      "height": 812
    }
  },
  "title": "课后服务 - 手机版配置",
  "type": "object",
  "properties": {
    "serviceTitle": {
      "type": "string",
      "title": "服务标题",
      "description": "课后服务包名称",
      "default": "全年系统包-L1"
    },
    "field": {
      "type": "string",
      "title": "功能图标",
      "default": "https://uiweb.oss-cn-chengdu.aliyuncs.com/img/学习页/课后/icon.png",
      "format": "image",
      "ui:options": {
        "category": "设计"
      }
    }
  },
  "required": []
}