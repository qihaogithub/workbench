<div class="page-wrapper">
  <!-- 状态栏 & 导航栏 -->
  <div class="nav-bar">
    <img
      src="https://uiweb.oss-cn-chengdu.aliyuncs.com/img/学习页/课后/手机/原生/导航&状态.png"
      alt="nav-status"
      class="nav-image"
    />
  </div>

  <!-- 主要内容区域 -->
  <div class="main-content">
    <!-- Banner 广告图 -->
    <div class="banner-wrapper">
      <img
        src="https://uiweb.oss-cn-chengdu.aliyuncs.com/img/学习页/课后/banner.png"
        alt="banner"
        class="banner-image"
        data-bind-src="bannerImage"
      />
    </div>

    <!-- 服务内容 -->
    <div class="service-section">
      <!-- 标题区 -->
      <div class="title-row">
        <span class="service-title" data-bind-text="serviceTitle">全年系统包-L1</span>
        <div class="teacher-info">
          <span class="teacher-label">苹果指导师</span>
          <img
            src="https://uiweb.oss-cn-chengdu.aliyuncs.com/img/学习页/课后/指导师头像.png"
            alt="teacher"
            class="teacher-avatar"
          />
        </div>
      </div>

      <!-- 功能入口列表 -->
      <div class="feature-list">
        <!-- 学习报告 -->
        <div class="feature-card">
          <div class="feature-left">
            <img
              src="https://uiweb.oss-cn-chengdu.aliyuncs.com/img/学习页/课后/icon.png"
              alt=""
              class="feature-icon"
            />
            <span class="feature-name">学习报告</span>
          </div>
          <div class="feature-right">
            <span class="feature-status">3篇报告未读</span>
            <svg class="chevron-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ffa66b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 18l6-6-6-6"/>
            </svg>
          </div>
        </div>

        <!-- 活动挑战 -->
        <div class="feature-card">
          <div class="feature-left">
            <img
              src="https://uiweb.oss-cn-chengdu.aliyuncs.com/img/学习页/课后/icon-1.png"
              alt=""
              class="feature-icon"
            />
            <span class="feature-name">活动挑战</span>
          </div>
          <div class="feature-right">
            <svg class="chevron-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ffa66b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 18l6-6-6-6"/>
            </svg>
          </div>
        </div>

        <!-- 趣味复习 -->
        <div class="feature-card">
          <div class="feature-left">
            <img
              src="https://uiweb.oss-cn-chengdu.aliyuncs.com/img/学习页/课后/icon-2.png"
              alt=""
              class="feature-icon"
            />
            <span class="feature-name">趣味复习</span>
          </div>
          <div class="feature-right">
            <svg class="chevron-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ffa66b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 18l6-6-6-6"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- 底部链接 -->
      <div class="bottom-link">
        <span class="bottom-link-text">查看往期课程服务</span>
        <svg class="chevron-icon chevron-gray" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#e0dfdf" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 18l6-6-6-6"/>
        </svg>
      </div>
    </div>
  </div>

  <!-- 底部指示条 -->
  <div class="bottom-indicator">
    <div class="indicator-bar"></div>
  </div>
</div>
