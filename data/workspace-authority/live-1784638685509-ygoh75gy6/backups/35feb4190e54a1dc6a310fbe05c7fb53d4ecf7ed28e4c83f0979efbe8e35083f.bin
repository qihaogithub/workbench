<div class="phone-popup-container">
  <div class="phone-popup-bg"></div>
  <div class="phone-popup-overlay">
    <div class="phone-popup-content">
      <img
        class="phone-popup-image"
        src="/api/images/7ff9e09eafad-popup-image.png"
        alt=""
        data-bind-src="popupImage"
      />
      <div class="phone-popup-actions">
        <div class="phone-popup-button" data-bind-text="mainButtonText">去看看</div>
        <span class="phone-popup-secondary" data-bind-text="secondaryButtonText">下次再说</span>
      </div>
    </div>
  </div>
</div>
