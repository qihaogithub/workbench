{
  "name": "@opencode-workbench/screenshot-service",
  "version": "1.0.0",
  "description": "Screenshot generation service using Puppeteer",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "build:docker": "esbuild src/server.ts --bundle --platform=node --target=node20 --outdir=dist --format=cjs --external:fastify --external:@fastify/cors --external:pino --external:pino-pretty --external:puppeteer-core --external:@opencode-workbench/shared",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@opencode-workbench/shared": "workspace:*",
    "dotenv": "^17.4.2",
    "fastify": "^4.26.0",
    "pino": "^8.0.0",
    "pino-pretty": "^10.0.0",
    "puppeteer-core": "^24.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
