{
  "name": "@opencode-workbench/agent-service",
  "version": "1.0.0",
  "description": "Independent Agent Service",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "build:docker": "esbuild src/server.ts --bundle --platform=node --target=node20 --outdir=dist --format=cjs --external:fastify --external:@fastify/cors --external:@fastify/rate-limit --external:@fastify/websocket --external:pino --external:pino-pretty --external:undici --external:ws",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "cross-env ACP_SMOKE_REAL=1 vitest run tests/integration",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.76.0",
    "@earendil-works/pi-ai": "0.76.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "@fastify/websocket": "^10.0.0",
    "@opencode-workbench/shared": "workspace:*",
    "dotenv": "^17.4.2",
    "fastify": "^4.26.0",
    "pino": "^8.0.0",
    "pino-pretty": "^10.0.0",
    "undici": "^6.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "cross-env": "^7.0.3",
    "esbuild": "^0.20.0",
    "eslint": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
