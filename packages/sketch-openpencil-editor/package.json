{
  "name": "@workbench/sketch-openpencil-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/sdk/index.js",
  "types": "./dist/sdk/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js"
    },
    "./adapter": {
      "types": "./dist/sdk/adapter.d.ts",
      "import": "./dist/sdk/adapter.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 3410",
    "build": "corepack pnpm run typecheck && vite build && corepack pnpm run build:sdk && corepack pnpm run check:assets",
    "build:sdk": "tsc -p tsconfig.sdk.json",
    "check:assets": "node scripts/check-openpencil-assets.mjs",
    "preview": "vite preview --host 127.0.0.1 --port 3410",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@open-pencil/core": "0.13.2",
    "@open-pencil/vue": "0.13.2",
    "@workbench/shared": "workspace:*",
    "canvaskit-wasm": "^0.40.0",
    "vue": "^3.5.29"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.3",
    "typescript": "^5.3.3",
    "vite": "^7.3.0",
    "vue-tsc": "^3.2.0"
  }
}
