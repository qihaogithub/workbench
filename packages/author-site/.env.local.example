# JWT 密钥（生产环境务必更换为强随机字符串）
# 运行以下命令生成安全的密钥：
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-key-change-this-in-production

# ============================================
# 内部 API Token（与 agent-service 共享）
# ============================================
# 用于 author-site 推送后端供应商配置到 agent-service
# 必须与根 .env 中的 INTERNAL_API_TOKEN 完全一致
# 运行时通过 /api/admin/backend-providers/sync 端点使用
INTERNAL_API_TOKEN=change-this-internal-shared-token-32bytes-min

# ============================================
# 服务地址配置（前端可访问）
# ============================================
NEXT_PUBLIC_AGENT_SERVICE_URL=http://localhost:3201
NEXT_PUBLIC_WEB_URL=http://localhost:3200

# ============================================
# Figma MCP 用户级授权（可选）
# ============================================
# 创建 Figma OAuth app 后填写。Redirect URI 需与 Figma app 配置完全一致。
FIGMA_OAUTH_CLIENT_ID=
FIGMA_OAUTH_CLIENT_SECRET=
FIGMA_OAUTH_REDIRECT_URI=http://localhost:3200/api/user/external-auth/figma/callback
# OAuth 成功后回到哪个创作端 origin；redirect URI 使用 Cloudflare tunnel 时建议保留本地 HTTP。
# FIGMA_OAUTH_POST_AUTH_ORIGIN=http://localhost:3200
# FIGMA_OAUTH_SCOPES=file_content:read
