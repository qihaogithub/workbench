{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@workbench/project-core": ["../project-core/src"],
      "@workbench/preview-contract": ["../preview-contract/src"],
      "@workbench/preview-contract/*": ["../preview-contract/src/*"],
      "@workbench/shared": ["../shared/src"],
      "@workbench/sketch-core": ["../sketch-core/src"],
      "@workbench/sketch-react": ["../sketch-react/src/index.tsx"],
      "@workbench/demo-ui": ["../demo-ui/src/index.ts"],
      "@workbench/demo-ui/*": ["../demo-ui/src/*"],
      "@workbench/shared/agent-prompts": ["../shared/src/agent-prompts/index.ts"],
      "@workbench/agent-client": ["../agent-client/src"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "data"]
}
