# Agent Service 配置
AGENT_SERVICE_URL=http://localhost:3201
# AGENT_SERVICE_API_KEY=your-api-key-here

# Figma MCP 用户级授权（可选）
# 创建 Figma OAuth app 后填写。Redirect URI 需与 Figma app 配置完全一致。
FIGMA_OAUTH_CLIENT_ID=
FIGMA_OAUTH_CLIENT_SECRET=
FIGMA_OAUTH_REDIRECT_URI=http://localhost:3200/api/user/external-auth/figma/callback
# Optional: where the browser returns after OAuth. Useful when redirect URI uses a public tunnel.
# FIGMA_OAUTH_POST_AUTH_ORIGIN=http://localhost:3200
# FIGMA_OAUTH_SCOPES=file_content:read

# CDN 基础地址（可选）
# 默认值：https://esm.sh
# 内网环境可替换为自建的 npm 代理地址，如：http://internal-cdn.example.com
# CDN_BASE_URL=https://esm.sh

# Demo 存储目录（可选）
# 默认值：./demos
# DEMOS_DIR=./demos
