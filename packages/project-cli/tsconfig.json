{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@workbench/preview-contract": ["../preview-contract/src/index.ts"],
      "@workbench/preview-contract/*": ["../preview-contract/src/*"],
      "@workbench/project-core": ["../project-core/src/index.ts"],
      "@workbench/project-scaffold": ["../project-scaffold/src/index.ts"]
    },
    "noEmit": true
  },
  "include": ["src/**/*.ts"]
}
