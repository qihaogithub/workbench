{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Button Demo Config",
  "type": "object",
  "properties": {
    "label": {
      "type": "string",
      "title": "Button Label",
      "default": "Click Me"
    },
    "variant": {
      "type": "string",
      "title": "Variant",
      "enum": ["primary", "secondary", "outline", "ghost", "destructive"],
      "enumNames": ["Primary", "Secondary", "Outline", "Ghost", "Destructive"],
      "default": "primary"
    },
    "size": {
      "type": "string",
      "title": "Size",
      "enum": ["sm", "md", "lg"],
      "enumNames": ["Small", "Medium", "Large"],
      "default": "md"
    },
    "disabled": {
      "type": "boolean",
      "title": "Disabled",
      "default": false
    }
  },
  "required": ["label", "variant", "size"]
}