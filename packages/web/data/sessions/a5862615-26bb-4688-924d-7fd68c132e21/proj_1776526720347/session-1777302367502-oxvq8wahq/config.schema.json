{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Simple Button Demo",
  "type": "object",
  "properties": {
    "label": {
      "type": "string",
      "title": "Button Text",
      "default": "Click Me"
    },
    "color": {
      "type": "string",
      "title": "Color",
      "enum": ["blue", "green", "red"],
      "enumNames": ["Blue", "Green", "Red"],
      "default": "blue"
    },
    "size": {
      "type": "string",
      "title": "Size",
      "enum": ["small", "medium", "large"],
      "enumNames": ["Small", "Medium", "Large"],
      "default": "medium"
    }
  },
  "required": ["label", "color", "size"]
}
