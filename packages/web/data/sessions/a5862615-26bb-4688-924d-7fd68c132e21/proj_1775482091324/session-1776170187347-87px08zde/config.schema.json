{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "轮播 Banner 配置",
  "type": "object",
  "properties": {
    "banner": {
      "type": "string",
      "format": "uri",
      "title": "轮播图片",
      "description": "轮播的主图片地址，系统会自动生成多张轮播图，支持 JPG、PNG、WebP 格式",
      "default": "https://picsum.photos/800/400"
    },
    "title": {
      "type": "string",
      "title": "轮播标题",
      "default": "精彩轮播展示",
      "maxLength": 30
    },
    "description": {
      "type": "string",
      "title": "轮播描述",
      "default": "左右滑动查看更多精彩内容"
    },
    "theme": {
      "type": "string",
      "title": "主题颜色",
      "enum": ["light", "dark", "colorful"],
      "enumNames": ["浅色模式", "深色模式", "多彩渐变"],
      "default": "light"
    },
    "showBadge": {
      "type": "boolean",
      "title": "显示轮播标签",
      "default": true
    }
  },
  "required": ["banner", "title"]
}
