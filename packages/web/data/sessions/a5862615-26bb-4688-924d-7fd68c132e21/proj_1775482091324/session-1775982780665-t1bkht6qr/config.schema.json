{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "轮播 Banner 配置",
  "type": "object",
  "properties": {
    "banners": {
      "type": "array",
      "title": "轮播图片列表",
      "description": "配置多张轮播图片，支持 JPG、PNG、WebP 格式",
      "items": {
        "type": "object",
        "properties": {
          "src": {
            "type": "string",
            "format": "uri",
            "title": "图片地址"
          },
          "alt": {
            "type": "string",
            "title": "图片描述"
          },
          "order": {
            "type": "number",
            "title": "显示顺序",
            "description": "图片在轮播中的顺序（数字越小越靠前）"
          }
        },
        "required": ["src"]
      },
      "default": [
        { "src": "https://picsum.photos/800/400?random=1", "alt": "轮播图 1", "order": 1 },
        { "src": "https://picsum.photos/800/400?random=2", "alt": "轮播图 2", "order": 2 },
        { "src": "https://picsum.photos/800/400?random=3", "alt": "轮播图 3", "order": 3 }
      ]
    },
    "theme": {
      "type": "string",
      "title": "主题颜色",
      "enum": ["light", "dark", "colorful"],
      "enumNames": ["浅色模式", "深色模式", "多彩渐变"],
      "default": "light"
    },
    "buttonText": {
      "type": "string",
      "title": "按钮文字",
      "description": "按钮上显示的文字内容",
      "default": "了解更多"
    },
    "buttonVariant": {
      "type": "string",
      "title": "按钮样式",
      "enum": ["primary", "secondary", "outline", "ghost"],
      "enumNames": ["主要按钮", "次要按钮", "描边按钮", "幽灵按钮"],
      "default": "primary"
    },
    "carouselOrder": {
      "type": "number",
      "title": "轮播组件顺序",
      "description": "轮播组件在布局中的位置（数字越小越靠前）",
      "default": 1
    },
    "buttonOrder": {
      "type": "number",
      "title": "按钮组件顺序",
      "description": "按钮在布局中的位置（数字越小越靠前）",
      "default": 2
    },
    "autoPlay": {
      "type": "boolean",
      "title": "自动轮播",
      "description": "是否启用自动轮播",
      "default": true
    },
    "autoPlayInterval": {
      "type": "number",
      "title": "自动轮播间隔",
      "description": "自动轮播的时间间隔（毫秒）",
      "default": 4000
    }
  },
  "required": ["banners"]
}
