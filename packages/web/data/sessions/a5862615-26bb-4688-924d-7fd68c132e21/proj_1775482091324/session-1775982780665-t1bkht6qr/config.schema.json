{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "轮播 Banner 配置",
  "type": "object",
  "properties": {
    "banner": {
      "type": "string",
      "format": "uri",
      "title": "轮播图片",
      "description": "轮播的主图片地址，系统会自动生成多张轮播图，支持 JPG、PNG、WebP 格式",
      "default": "https://picsum.photos/800/400"
    },
    "theme": {
      "type": "string",
      "title": "主题颜色",
      "enum": ["light", "dark", "colorful"],
      "enumNames": ["浅色模式", "深色模式", "多彩渐变"],
      "default": "light"
    }
  },
  "required": ["banner"]
}
