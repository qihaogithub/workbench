{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "轮播图配置",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "title": "标题",
      "default": "轮播图"
    },
    "autoPlay": {
      "type": "boolean",
      "title": "自动播放",
      "default": true
    },
    "interval": {
      "type": "number",
      "title": "轮播间隔（毫秒）",
      "default": 3000,
      "minimum": 1000,
      "maximum": 10000
    },
    "images": {
      "type": "array",
      "title": "图片列表",
      "default": [
        {
          "url": "https://picsum.photos/800/400?random=1",
          "alt": "图片 1"
        },
        {
          "url": "https://picsum.photos/800/400?random=2",
          "alt": "图片 2"
        },
        {
          "url": "https://picsum.photos/800/400?random=3",
          "alt": "图片 3"
        }
      ],
      "items": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "title": "图片地址"
          },
          "alt": {
            "type": "string",
            "title": "图片描述"
          }
        },
        "required": ["url"]
      }
    },
    "showArrows": {
      "type": "boolean",
      "title": "显示左右箭头",
      "default": true
    },
    "showDots": {
      "type": "boolean",
      "title": "显示指示点",
      "default": true
    },
    "height": {
      "type": "string",
      "title": "轮播图高度",
      "default": "400px"
    }
  },
  "required": ["title"]
}
