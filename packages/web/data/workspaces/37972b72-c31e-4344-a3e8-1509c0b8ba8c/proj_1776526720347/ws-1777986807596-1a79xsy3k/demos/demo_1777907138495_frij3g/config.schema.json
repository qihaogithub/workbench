{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "炫彩卡片展示 (iPad Mini)",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "title": "标题",
      "default": "✨ 炫彩世界"
    },
    "subtitle": {
      "type": "string",
      "title": "副标题",
      "default": "探索色彩的无限可能"
    },
    "cardCount": {
      "type": "number",
      "title": "卡片数量",
      "minimum": 3,
      "maximum": 12,
      "default": 6
    },
    "enableAnimation": {
      "type": "boolean",
      "title": "启用动画效果",
      "default": true
    }
  },
  "required": [
    "title"
  ]
}