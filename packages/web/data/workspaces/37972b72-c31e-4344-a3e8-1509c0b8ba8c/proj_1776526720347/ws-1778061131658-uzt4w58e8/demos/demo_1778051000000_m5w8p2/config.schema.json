{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Dashboard Config",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "title": "仪表盘标题",
      "default": "📊 数据仪表盘"
    },
    "period": {
      "type": "string",
      "title": "默认时间周期",
      "enum": ["今日", "本周", "本月"],
      "default": "今日"
    },
    "showRevenue": {
      "type": "boolean",
      "title": "显示收入卡片",
      "default": true
    },
    "showUsers": {
      "type": "boolean",
      "title": "显示用户卡片",
      "default": true
    },
    "showOrders": {
      "type": "boolean",
      "title": "显示订单卡片",
      "default": true
    },
    "showGrowth": {
      "type": "boolean",
      "title": "显示增长率卡片",
      "default": true
    },
    "chartStyle": {
      "type": "string",
      "title": "图表样式",
      "enum": ["bar", "line", "area"],
      "enumNames": ["柱状图", "折线图", "面积图"],
      "default": "bar"
    }
  }
}