{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "粒子星空配置",
  "description": "宇宙粒子星空探索页面的配置项",
  "type": "object",
  "properties": {
    "particleCount": {
      "type": "number",
      "title": "粒子数量",
      "description": "星空中粒子的数量",
      "default": 160,
      "minimum": 30,
      "maximum": 300
    },
    "particleSpeed": {
      "type": "number",
      "title": "粒子速度",
      "description": "粒子漂浮运动的速率",
      "default": 0.3,
      "minimum": 0.05,
      "maximum": 2
    },
    "connectionDistance": {
      "type": "number",
      "title": "连接距离",
      "description": "粒子之间产生连接线的最大距离（像素）",
      "default": 130,
      "minimum": 30,
      "maximum": 300
    },
    "primaryColor": {
      "type": "string",
      "title": "主题色",
      "description": "页面主色调（CSS 颜色值）",
      "default": "#8B5CF6",
      "format": "color"
    },
    "glowIntensity": {
      "type": "number",
      "title": "发光强度",
      "description": "粒子的光晕强度倍数",
      "default": 1,
      "minimum": 0.2,
      "maximum": 3
    }
  }
}
