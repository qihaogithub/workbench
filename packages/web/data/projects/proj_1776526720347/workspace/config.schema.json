{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Banner Demo Config",
  "type": "object",
  "properties": {
    "banner": {
      "type": "string",
      "title": "Banner",
      "description": "Recommended size: 750x400px, supports JPG, PNG, WebP formats",
      "default": "https://picsum.photos/750/400",
      "ui:widget": "file",
      "ui:options": {
        "accept": "image/*",
        "maxSize": 5242880,
        "placeholder": "Enter image URL or upload"
      }
    },
    "title": {
      "type": "string",
      "title": "Event Title",
      "default": "Exciting Event Coming",
      "maxLength": 20
    },
    "description": {
      "type": "string",
      "title": "Event Description",
      "default": "Limited time offer, don't miss out"
    },
    "theme": {
      "type": "string",
      "title": "Theme Color",
      "enum": ["light", "dark", "colorful"],
      "enumNames": ["Light Mode", "Dark Mode", "Colorful Gradient"],
      "default": "light"
    },
    "showBadge": {
      "type": "boolean",
      "title": "Show Event Badge",
      "default": true
    }
  },
  "required": ["banner", "title"]
}