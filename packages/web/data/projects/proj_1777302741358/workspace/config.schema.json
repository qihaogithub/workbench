{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "图片上传测试",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "title": "标题",
      "default": "图片上传测试"
    },
    "description": {
      "type": "string",
      "title": "描述",
      "default": "测试单图和多图上传功能"
    },
    "banner": {
      "type": "string",
      "title": "横幅图片",
      "description": "支持 URL 或本地上传，建议尺寸 1200x400",
      "default": "",
      "ui:widget": "file",
      "ui:options": {
        "accept": "image/*",
        "maxSize": 5242880,
        "placeholder": "输入图片 URL 或上传"
      }
    },
    "avatar": {
      "type": "string",
      "title": "头像",
      "description": "支持 URL 或本地上传",
      "default": "",
      "ui:widget": "file",
      "ui:options": {
        "accept": "image/*",
        "maxSize": 2097152,
        "placeholder": "输入图片 URL 或上传"
      }
    },
    "gallery": {
      "type": "array",
      "title": "图片画廊",
      "description": "支持 URL 添加或本地上传多张图片",
      "items": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "alt": {
            "type": "string"
          }
        }
      },
      "default": [],
      "ui:widget": "imageList",
      "ui:options": {
        "accept": "image/*",
        "maxSize": 2097152,
        "maxItems": 20
      }
    }
  },
  "required": ["title"]
}
