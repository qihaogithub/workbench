{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Weather Mood Widget Config",
  "type": "object",
  "properties": {
    "city": {
      "type": "string",
      "title": "城市名称",
      "default": "北京",
      "maxLength": 10
    },
    "unit": {
      "type": "string",
      "title": "温度单位",
      "enum": ["celsius", "fahrenheit"],
      "enumNames": ["摄氏度 (°C)", "华氏度 (°F)"],
      "default": "celsius"
    },
    "showMood": {
      "type": "boolean",
      "title": "显示心情小贴士",
      "default": true
    },
    "animationSpeed": {
      "type": "string",
      "title": "动画速度",
      "enum": ["slow", "medium", "fast"],
      "enumNames": ["慢速", "中速", "快速"],
      "default": "medium"
    },
    "defaultWeather": {
      "type": "string",
      "title": "默认天气",
      "enum": ["sunny", "cloudy", "rainy", "snowy", "stormy"],
      "enumNames": ["☀️ 晴天", "☁️ 多云", "🌧️ 雨天", "❄️ 雪天", "⚡ 雷雨"],
      "default": "sunny"
    }
  }
}
