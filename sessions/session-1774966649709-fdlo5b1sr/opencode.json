{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": {
      "*": "deny",
      "index.tsx": "allow",
      "config.schema.json": "allow",
      "AGENTS.md": "allow"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "cat *": "allow",
      "grep *": "allow",
      "rm *": "deny",
      "mv *": "deny",
      "cp *": "deny",
      "mkdir *": "deny"
    },
    "external_directory": {
      "**/packages/shared/sdk/**": "allow",
      "**/demos/**": "allow"
    }
  }
}