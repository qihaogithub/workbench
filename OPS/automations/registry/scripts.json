    {
      "id": "sync-status-flap",
      "kind": "development-diagnostic",
      "title": "Sync status flap detector",
      "path": "scripts/development/detect-sync-status-flap.mjs",
      "command": "corepack pnpm test:sync-status-flap",
      "ownerArea": "author-site:sync",
      "status": "active",
      "automationLevel": "report-only",
      "requiresServices": [
        "author-site",
        "agent-service"
      ],
      "writes": [
        "tmp/sync-status-flap/"
      ],
      "docs": [
        "scripts/development/README.md"
      ],
      "notes": "Samples visible sync status text, probes workspace flush, and reports repeated online/offline flapping or visible sync failure."
    },
